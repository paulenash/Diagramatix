generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ────────────────────────────────────────────────────────────────────────────
// CPS 230 Phase 0 — Multi-tenancy foundation
//
// Org is the regulated-entity boundary. Every Project and Diagram belongs to
// exactly one Org (initially nullable for backfill, will be tightened to
// NOT NULL after the data migration runs successfully).
// ────────────────────────────────────────────────────────────────────────────

enum OrgEntityType {
  ADI
  Insurer
  LifeInsurer
  HealthInsurer
  RSE
  Other
}

enum OrgRole {
  Owner // full control of the org, including billing and deletion
  Admin // manage members and settings, no destructive ops
  RiskOwner // create/edit Risks, Controls, link to processes
  ProcessOwner // create/edit critical operations + BPMN process content
  ControlOwner // edit Controls and test outcomes
  InternalAudit // read-only across the whole org, can export
  BoardObserver // read-only access to BCPs, registers and dashboards
  Viewer // read-only access to diagrams and registers
}

// Project sharing — a Project owner can grant another registered user
// either VIEW or EDIT access to a Project they own (see ProjectShare
// below). VIEW = read diagrams; EDIT = read + mutate diagram content
// (data / colour / displayMode / name) but NOT delete the project,
// delete diagrams, or change the share list. Destructive + share-
// management actions stay owner-only.
enum ProjectShareRole {
  VIEW
  EDIT
}

model Org {
  id         String        @id @default(cuid())
  name       String
  entityType OrgEntityType @default(Other)
  createdAt  DateTime      @default(now())

  // Per-org admin setting (managed by Org Owner/Admin via /dashboard/admin).
  // When false, project sharing is restricted to users in the same Org as
  // the project owner. When true, the owner can share with any registered
  // user. Defaults to false so cross-tenant data stays contained until an
  // org admin explicitly opts in.
  allowCrossOrgSharing Boolean @default(false)

  members             OrgMember[]
  projects            Project[]
  diagrams            Diagram[]
  prompts             Prompt[]
  diagramRules        DiagramRules[]
  collaborationGroups CollaborationGroup[]
}

model OrgMember {
  id        String   @id @default(cuid())
  orgId     String
  org       Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      OrgRole
  createdAt DateTime @default(now())
  // Actor's userId at the moment this membership was created or
  // promoted. Optional + no FK so the audit hint survives if the
  // actor is later deleted. NULL on pre-feature rows. Mirrors the
  // ProjectShare.createdBy pattern.
  createdBy String?

  @@unique([orgId, userId])
  @@index([userId])
}

// ────────────────────────────────────────────────────────────────────────────
// Existing models — Org back-relations and orgId added
// ────────────────────────────────────────────────────────────────────────────

model User {
  id                            String                     @id @default(cuid())
  email                         String                     @unique
  name                          String?
  password                      String                     @default("")
  resetToken                    String?                    @unique
  resetTokenExpiry              DateTime?
  diagrams                      Diagram[]
  projects                      Project[]
  templates                     DiagramTemplate[]
  orgMembers                    OrgMember[]
  prompts                       Prompt[]
  diagramRules                  DiagramRules[]
  // Subscription tier. Nullable for migration safety; the seed script
  // grandfathers every existing user to "expert" and the registration
  // flow sets "free" on new sign-ups. Admins (per SUPERUSER_EMAILS in
  // app/lib/superuser.ts) bypass all limits regardless of this field —
  // the "Administration" tier shown in the UI is derived, not stored.
  subscriptionLevelId           String?
  subscriptionLevel             SubscriptionLevel?         @relation(fields: [subscriptionLevelId], references: [id])
  // When the user landed on their current tier. Drives Free-tier trial
  // expiry (30 days from this date for Free). Set on registration and
  // updated by the admin "Change Tier" action.
  subscriptionAssignedAt        DateTime?
  // True once the user has actively chosen (or skipped past) the
  // welcome tier picker. Existing users are backfilled to true by
  // scripts/seed-subscriptions.ts so they don't see the picker on
  // their next visit. New sign-ups start at false; the dashboard
  // shows the TierPicker modal until the user picks or skips.
  hasChosenTier                 Boolean                    @default(false)
  // ── Stripe wiring (Subscriptions Phase 2) ────────────────────────────
  // Stripe Customer ID for this user. Created lazily on first Checkout
  // session attempt; reused for all subsequent payments and Portal
  // sessions so cards / invoices stay attached to one Customer.
  stripeCustomerId              String?                    @unique
  // Active Stripe Subscription ID. Null while on Free or after a fully-
  // expired cancellation. Set by the `checkout.session.completed`
  // webhook and cleared by `customer.subscription.deleted` once the
  // grace period (subscriptionEndsAt) elapses.
  stripeSubscriptionId          String?                    @unique
  // Mirror of Stripe's subscription status. Drives UI badges (past_due
  // warning chip, etc.). Values we set: "active" | "trialing" |
  // "past_due" | "canceled" | "incomplete". Null = no Stripe subscription.
  stripeSubscriptionStatus      String?
  // Copied from Stripe — when the current billing period ends / renews.
  // The webhook updates this on every subscription.updated event.
  currentPeriodEnd              DateTime?
  // Cancellation grace marker. Set to currentPeriodEnd when Stripe
  // emits subscription.deleted. While now() < this date the user keeps
  // their paid tier; after, `getEffectiveSubscriptionLevelId` returns
  // "free" so we downgrade lazily without a cron job.
  subscriptionEndsAt            DateTime?
  // ── Admin-granted comp tier (Option A from 2026-05-25) ───────────────
  // Lets an admin temporarily grant a higher tier to a user (e.g. comp
  // an influencer to Expert for 30 days) without touching their
  // underlying Stripe subscription. While compTierExpiresAt > now AND
  // compTierLevelId is set, `getEffectiveSubscriptionLevelId` returns
  // the comp tier instead of the paid tier. After expiry, the user
  // reverts silently to whatever their underlying subscription says.
  compTierLevelId               String?
  compTierExpiresAt             DateTime?
  // Audit: when the comp was granted (most recent grant if multiple).
  // A future CompGrant table can replace this with a full log, but
  // for now we just track the latest issue date.
  compTierGrantedAt             DateTime?
  usageCounters                 UsageCounter[]
  // Per-user UI prefs. Currently stores the collapsed state of
  // template-group headers in the editor menu, keyed like
  // `{ "user:Group A": true, "builtin:Group B": false }`. Templates'
  // group field is the source of truth; this just remembers which
  // headers the user wants folded.
  templateGroupPrefs            Json?
  createdAt                     DateTime                   @default(now())
  // Updated (throttled) from the Auth.js jwt callback to power the
  // admin "online / last seen" indicator. Nullable for legacy rows.
  lastSeenAt                    DateTime?
  // The diagram the user is currently viewing — set when a diagram page
  // loads, cleared when they navigate back to the dashboard / a project.
  // Denormalised name avoids a join in the admin Registered Users query.
  currentDiagramId              String?
  currentDiagramName            String?
  // Collaboration Groups (Phase 1) back-relations.
  collaborationGroupsOwned      CollaborationGroup[]       @relation("CollaborationGroupOwner")
  collaborationGroupMemberships CollaborationGroupMember[] @relation("CollaborationGroupMembership")
  collaborationGroupInvitesSent CollaborationGroupMember[] @relation("CollaborationGroupInvitesSent")
  ownershipTransfersFrom        OwnershipTransfer[]        @relation("OwnershipTransferFrom")
  ownershipTransfersTo          OwnershipTransfer[]        @relation("OwnershipTransferTo")
  notifications                 Notification[]
  // Phase 2 — Send for Review back-relations.
  diagramReviewsRequested       DiagramReview[]            @relation("DiagramReviewRequester")
  diagramReviewerEntries        DiagramReviewer[]          @relation("DiagramReviewerUser")
  // Project-sharing back-relations.
  projectShares                 ProjectShare[]             @relation("ProjectShareRecipient")
  diagramsOwned                 Diagram[]                  @relation("DiagramOwner")
}

model Project {
  id          String    @id @default(cuid())
  name        String
  description String    @default("")
  ownerName   String    @default("")
  colorConfig Json      @default("{}")
  fontConfig  Json      @default("{}")
  folderTree  Json      @default("{}")
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Org scoping — required after Phase 0 backfill (scripts/backfill-orgs.ts).
  orgId       String
  org         Org       @relation(fields: [orgId], references: [id], onDelete: Restrict)
  diagrams    Diagram[]
  // Users this project is shared with, plus their role (VIEW / EDIT).
  shares      ProjectShare[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([orgId])
}

// One row per (project, user) pair the owner has shared the project with.
// Owners never appear here — their ownership is on Project.userId. Recipients
// have either VIEW or EDIT permission. Deleting the Project or the User
// cascades to the share rows.
model ProjectShare {
  id        String           @id @default(cuid())
  projectId String
  project   Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User             @relation("ProjectShareRecipient", fields: [userId], references: [id], onDelete: Cascade)
  role      ProjectShareRole
  createdAt DateTime         @default(now())
  // Owner who added this share. Plain string (no FK) so the audit
  // breadcrumb survives if the granting owner is later deleted.
  createdBy String?

  @@unique([projectId, userId])
  @@index([userId])
}

model Diagram {
  id          String           @id @default(cuid())
  name        String
  type        String           @default("basic")
  data        Json             @default("{}")
  colorConfig Json             @default("{}")
  displayMode String           @default("normal")
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId   String?
  project     Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  // Denormalised from Project for query performance — kept in sync by the
  // application layer. Required after Phase 0 backfill.
  orgId       String
  org         Org              @relation(fields: [orgId], references: [id], onDelete: Restrict)
  // Per-diagram accountability label. Defaults to the project owner at
  // creation; mutable by the project owner only (editors and viewers see
  // it read-only). Distinct from the free-text Process Owner inside the
  // DiagramData. SetNull on user delete preserves diagram history with
  // an empty owner slot. Nullable so the field can be added to existing
  // rows without a destructive migration (backfilled by
  // scripts/backfill-project-sharing.ts).
  diagramOwnerId String?
  diagramOwner   User?         @relation("DiagramOwner", fields: [diagramOwnerId], references: [id], onDelete: SetNull)
  history     DiagramHistory[]
  reviews     DiagramReview[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([orgId])
  @@index([diagramOwnerId])
}

model DiagramHistory {
  id        String   @id @default(cuid())
  diagramId String
  diagram   Diagram  @relation(fields: [diagramId], references: [id], onDelete: Cascade)
  snapshot  Json // full diagram data { name, type, data, colorConfig, displayMode }
  userId    String? // who triggered the save (nullable for legacy)
  createdAt DateTime @default(now())

  @@index([diagramId, createdAt])
}

model DiagramTemplate {
  id           String   @id @default(cuid())
  name         String
  diagramType  String   @default("bpmn")
  templateType String   @default("user")
  // Free-form group name. Null = ungrouped. Same name across multiple
  // templates clusters them under one collapsible header in the editor
  // menu. User and builtin clusters are independent (user-template
  // "Patterns" and builtin-template "Patterns" are two separate groups).
  group        String?
  data         Json     @default("{}")
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Prompt {
  id            String    @id @default(cuid())
  name          String
  text          String
  diagramType   String    @default("bpmn")
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  orgId         String
  org           Org       @relation(fields: [orgId], references: [id], onDelete: Restrict)
  // Last edited 2-phase AI Plan for this prompt (AiElement[] + AiConnection[]).
  // null until the user saves with a plan present.
  planJson      Json?
  planUpdatedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([orgId])
  @@index([userId, diagramType])
}

model DiagramRules {
  id        String   @id @default(cuid())
  category  String // "general", "bpmn", "state-machine", "value-chain", "domain", "context", "process-context"
  rules     String // multiline text — numbered rules in groups
  isDefault Boolean  @default(false) // true = admin-set system default
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orgId     String?
  org       Org?     @relation(fields: [orgId], references: [id], onDelete: Restrict)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([category, userId, orgId]) // one set of rules per category per user per org
}

// ────────────────────────────────────────────────────────────────────────────
// Subscriptions — four real tiers (Free / Introductory / Professional /
// Expert) plus a derived "Administration" view for SUPERUSER_EMAILS users
// (never stored as a row, never enforces limits).
//
// SubscriptionLevel rows are seeded with the canonical limits but editable
// by admins via /dashboard/admin/subscriptions. Limit columns are nullable
// where null = unlimited.
//
// UsageCounter tracks event metrics (AI attempts, exports, imports) keyed
// by (userId, periodKey, metric). periodKey is "YYYY-MM" for monthly
// resetting counters and "all-time" for Free's lifetime counters.
// Point-in-time metrics (project count, diagram count, archimate total,
// element counts) are computed from the actual tables and don't need a
// UsageCounter row.
// ────────────────────────────────────────────────────────────────────────────

model SubscriptionLevel {
  id           String @id // "free" | "introductory" | "professional" | "expert"
  name         String // display name
  priceMonthly Int    @default(0) // AUD cents
  sortOrder    Int // for UI ordering

  // Limits. null = unlimited.
  maxProjects                   Int?
  maxDiagramsPerTypePerProject  Int?
  maxArchimateDiagramsTotal     Int?
  maxNonBpmnElementsPerDiagram  Int?
  maxBpmnElementsPerDiagram     Int?
  maxAiAttempts                 Int?
  aiAttemptsResetMonthly        Boolean @default(true) // false → lifetime counter (Free)
  maxIndividualExports          Int?
  individualExportsResetMonthly Boolean @default(true)
  maxIndividualImports          Int?
  individualImportsResetMonthly Boolean @default(true)
  maxBulkExports                Int?
  maxBulkImports                Int?
  // Days from subscriptionAssignedAt before the tier expires and the
  // user is soft-blocked from any further creation / AI / export /
  // import action. Null = no expiry (the default for paid tiers).
  // Free is seeded with 30.
  trialDays                     Int?

  // Stripe Price ID linking this tier to a recurring price in Stripe.
  // Null for Free (no payment). Set once via the admin Subscriptions
  // editor (or a seed script) after creating the matching Product +
  // Price in the Stripe dashboard. The Checkout flow looks this up by
  // tier ID and refuses to start if it's missing for a paid tier.
  stripePriceId String?

  users     User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UsageCounter {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  periodKey String // "2026-05" | "all-time"
  metric    String // "ai_attempts" | "individual_exports" | "individual_imports" | "bulk_exports" | "bulk_imports"
  count     Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([userId, periodKey, metric])
  @@index([userId])
}

// ────────────────────────────────────────────────────────────────────────────
// Feature catalog — admin-editable, two-stage (draft + published).
//
// Admin edits the `name` / `summary` / `details` / `hidden` / `sortOrder`
// fields freely. They show up in the admin editor only. The dashboard
// "Features" modal AND the public /features marketing page read the
// `published*` mirror fields exclusively. Clicking "Publish All" in
// the admin editor copies draft → published in one transaction.
//
// `details` is markdown — typically a list of 3-5 bullets per feature.
// Stored as one string so the editor stays simple (no per-bullet rows).
// ────────────────────────────────────────────────────────────────────────────

model Feature {
  id        String @id @default(cuid())
  sortOrder Int    @default(0)

  // Draft fields — only admins see these.
  name    String
  summary String
  details String
  hidden  Boolean @default(false)

  // Published snapshot — what the marketing page + dashboard show.
  // Null = never published yet.
  publishedName      String?
  publishedSummary   String?
  publishedDetails   String?
  publishedHidden    Boolean?
  publishedSortOrder Int?
  publishedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Admin-editable per-diagram-type bubble-help cards. Each row binds a
// code-level trigger (`topicKey`, e.g. "create-connector",
// "select-multiple") to the human-readable text shown in the cloud and
// the duration the cloud stays visible. `conditionLabel` is purely
// descriptive — it lets admins remember what each topic key fires on
// (e.g. "Click on an Element"). One set per diagramType — global
// across all users / diagrams of that type.
model BubbleHelp {
  id             String   @id @default(cuid())
  diagramType    String
  topicKey       String
  conditionLabel String
  text           String
  durationMs     Int      @default(10000)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([diagramType, topicKey])
  @@index([diagramType])
}

// ────────────────────────────────────────────────────────────────────────────
// Collaboration Groups + in-app Notifications (Phase 1 of the Collaboration
// Groups feature). Phase 2 adds DiagramReview / DiagramReviewer; Phase 3
// adds the connector-kind columns. See plan in
// `.claude/plans/nifty-singing-hennessy.md`.
// ────────────────────────────────────────────────────────────────────────────

// Minimal in-app notification inbox. Polled from the dashboard bell.
// `type` is a string discriminator (kept loose so Phases 2 + 3 can add
// new event types without a schema bump); `payload` is the type-specific
// JSON used by the bell popover to render the link / row.
model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  payload   Json
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

model CollaborationGroup {
  id         String   @id @default(cuid())
  name       String
  ownerId    String
  owner      User     @relation("CollaborationGroupOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  // When set, this is the auto-created Org-wide group. Org Owner is
  // the group's owner; deletion / rename are forbidden in v1.
  orgId      String?
  org        Org?     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  isOrgGroup Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  members   CollaborationGroupMember[]
  transfers OwnershipTransfer[]
  reviews   DiagramReview[]

  @@index([ownerId])
  @@index([orgId])
}

model CollaborationGroupMember {
  id          String             @id @default(cuid())
  groupId     String
  group       CollaborationGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId      String
  user        User               @relation("CollaborationGroupMembership", fields: [userId], references: [id], onDelete: Cascade)
  // "invited" | "accepted" | "declined" | "left" | "removed"
  status      String
  invitedAt   DateTime           @default(now())
  joinedAt    DateTime?
  invitedById String?
  invitedBy   User?              @relation("CollaborationGroupInvitesSent", fields: [invitedById], references: [id], onDelete: SetNull)

  @@unique([groupId, userId])
  @@index([userId, status])
}

// Phase 2 — Send for Review. One DiagramReview per (diagram, group) the
// owner sends to; one DiagramReviewer per assigned reviewer within it.
// Both feed the virtual "Diagrams Sent / Received for Review" projects —
// membership is derived from these rows, not Diagram.projectId.
model DiagramReview {
  id          String          @id @default(cuid())
  diagramId   String
  diagram     Diagram         @relation(fields: [diagramId], references: [id], onDelete: Cascade)
  groupId     String
  group       CollaborationGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  requesterId String
  requester   User            @relation("DiagramReviewRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  objective   String
  dueDate     DateTime
  // "open" | "resubmitted" | "closed"
  status      String          @default("open")
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  reviewers   DiagramReviewer[]

  @@index([diagramId])
  @@index([groupId])
  @@index([requesterId])
}

model DiagramReviewer {
  id             String        @id @default(cuid())
  reviewId       String
  review         DiagramReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  userId         String
  user           User          @relation("DiagramReviewerUser", fields: [userId], references: [id], onDelete: Cascade)
  // "pending" | "in-progress" | "submitted" | "approved" | "declined-to-review"
  status         String        @default("pending")
  lastActivityAt DateTime?

  @@unique([reviewId, userId])
  @@index([userId, status])
}

model OwnershipTransfer {
  id         String             @id @default(cuid())
  groupId    String
  group      CollaborationGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  fromUserId String
  fromUser   User               @relation("OwnershipTransferFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUserId   String
  toUser     User               @relation("OwnershipTransferTo", fields: [toUserId], references: [id], onDelete: Cascade)
  // "pending" | "accepted" | "declined" | "cancelled"
  status     String             @default("pending")
  createdAt  DateTime           @default(now())
  resolvedAt DateTime?

  @@index([toUserId, status])
  @@index([groupId, status])
}
