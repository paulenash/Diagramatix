generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ────────────────────────────────────────────────────────────────────────────
// CPS 230 Phase 0 — Multi-tenancy foundation
//
// Org is the regulated-entity boundary. Every Project and Diagram belongs to
// exactly one Org (initially nullable for backfill, will be tightened to
// NOT NULL after the data migration runs successfully).
// ────────────────────────────────────────────────────────────────────────────

enum OrgEntityType {
  ADI
  Insurer
  LifeInsurer
  HealthInsurer
  RSE
  Other
}

enum OrgRole {
  Owner // full control of the org, including billing and deletion
  Admin // manage members and settings, no destructive ops
  RiskOwner // create/edit Risks, Controls, link to processes
  ProcessOwner // create/edit critical operations + BPMN process content
  ControlOwner // edit Controls and test outcomes
  InternalAudit // read-only across the whole org, can export
  BoardObserver // read-only access to BCPs, registers and dashboards
  Viewer // read-only access to diagrams and registers
}

// Project sharing — a Project owner can grant another registered user
// either VIEW or EDIT access to a Project they own (see ProjectShare
// below). VIEW = read diagrams; EDIT = read + mutate diagram content
// (data / colour / displayMode / name) but NOT delete the project,
// delete diagrams, or change the share list. Destructive + share-
// management actions stay owner-only.
enum ProjectShareRole {
  VIEW
  EDIT
}

// BPMN lifecycle (publish + review cadence). Persisted on Diagram.
// DRAFT     = never published; has no PublishedVersion rows.
// PUBLISHED = at least one PublishedVersion exists; currentPublishedVersionId points at the latest.
// ARCHIVED  = owner-marked; hidden from business users via bundle access checks.
// IN_REVIEW and REVIEW_DUE are NOT stored — they're derived badges on top of
// the persisted state (any open DiagramReview row, nextReviewDate <= today).
enum DiagramLifecycle {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// Status of a single piece of business-user feedback against a published version.
enum FeedbackStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
  DISMISSED
}

model Org {
  id         String        @id @default(cuid())
  name       String
  entityType OrgEntityType @default(Other)
  createdAt  DateTime      @default(now())

  // Per-org admin setting (managed by Org Owner/Admin via /dashboard/admin).
  // When false, project sharing is restricted to users in the same Org as
  // the project owner. When true, the owner can share with any registered
  // user. Defaults to false so cross-tenant data stays contained until an
  // org admin explicitly opts in.
  allowCrossOrgSharing Boolean @default(false)

  members             OrgMember[]
  memberTeams         OrgMemberTeam[]
  projects            Project[]
  diagrams            Diagram[]
  prompts             Prompt[]
  diagramRules        DiagramRules[]
  collaborationGroups CollaborationGroup[]
  entityLists         EntityList[]
  entityStructures    EntityStructure[]
  riskControlLibraries RiskControlLibrary[]
  pcfFrameworks       PcfFramework[]
  simulationTeams     SimulationTeam[]
  simulationCalendars SimulationCalendar[]
  processMiningRuns   ProcessMiningRun[]
}

model OrgMember {
  id        String   @id @default(cuid())
  orgId     String
  org       Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      OrgRole
  createdAt DateTime @default(now())
  // Actor's userId at the moment this membership was created or
  // promoted. Optional + no FK so the audit hint survives if the
  // actor is later deleted. NULL on pre-feature rows. Mirrors the
  // ProjectShare.createdBy pattern.
  createdBy String?

  @@unique([orgId, userId])
  @@index([userId])
}

// Admin-managed team/role membership: which Org-Structure EntityNode(s) a user
// belongs to. Assigned by an OrgAdmin (own org) or SuperAdmin (any org) — never
// self-service. Powers the Process Portal's "Involving me" view (processes that
// reference my team, or any role beneath it). `entityNodeId` points at an
// org-master OrgStructure EntityNode; plain id (no FK) so re-seeding the Entity
// List doesn't cascade-delete memberships — the Portal tolerates a stale id.
model OrgMemberTeam {
  id           String   @id @default(cuid())
  orgId        String
  org          Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  entityNodeId String
  createdAt    DateTime @default(now())
  createdById  String?

  @@unique([orgId, userId, entityNodeId])
  @@index([orgId, userId])
  @@index([entityNodeId])
}

// ────────────────────────────────────────────────────────────────────────────
// Existing models — Org back-relations and orgId added
// ────────────────────────────────────────────────────────────────────────────

model User {
  id                            String                     @id @default(cuid())
  email                         String                     @unique
  name                          String?
  password                      String                     @default("")
  resetToken                    String?                    @unique
  resetTokenExpiry              DateTime?
  diagrams                      Diagram[]
  projects                      Project[]
  templates                     DiagramTemplate[]
  orgMembers                    OrgMember[]
  orgMemberTeams                OrgMemberTeam[]
  prompts                       Prompt[]
  diagramRules                  DiagramRules[]
  // Subscription tier. Nullable for migration safety; the seed script
  // grandfathers every existing user to "expert" and the registration
  // flow sets "free" on new sign-ups. Admins (per SUPERUSER_EMAILS in
  // app/lib/superuser.ts) bypass all limits regardless of this field —
  // the "Administration" tier shown in the UI is derived, not stored.
  subscriptionLevelId           String?
  subscriptionLevel             SubscriptionLevel?         @relation(fields: [subscriptionLevelId], references: [id])
  // When the user landed on their current tier. Drives Free-tier trial
  // expiry (30 days from this date for Free). Set on registration and
  // updated by the admin "Change Tier" action.
  subscriptionAssignedAt        DateTime?
  // True once the user has actively chosen (or skipped past) the
  // welcome tier picker. Existing users are backfilled to true by
  // scripts/seed-subscriptions.ts so they don't see the picker on
  // their next visit. New sign-ups start at false; the dashboard
  // shows the TierPicker modal until the user picks or skips.
  hasChosenTier                 Boolean                    @default(false)
  // ── Stripe wiring (Subscriptions Phase 2) ────────────────────────────
  // Stripe Customer ID for this user. Created lazily on first Checkout
  // session attempt; reused for all subsequent payments and Portal
  // sessions so cards / invoices stay attached to one Customer.
  stripeCustomerId              String?                    @unique
  // Active Stripe Subscription ID. Null while on Free or after a fully-
  // expired cancellation. Set by the `checkout.session.completed`
  // webhook and cleared by `customer.subscription.deleted` once the
  // grace period (subscriptionEndsAt) elapses.
  stripeSubscriptionId          String?                    @unique
  // Mirror of Stripe's subscription status. Drives UI badges (past_due
  // warning chip, etc.). Values we set: "active" | "trialing" |
  // "past_due" | "canceled" | "incomplete". Null = no Stripe subscription.
  stripeSubscriptionStatus      String?
  // Copied from Stripe — when the current billing period ends / renews.
  // The webhook updates this on every subscription.updated event.
  currentPeriodEnd              DateTime?
  // Cancellation grace marker. Set to currentPeriodEnd when Stripe
  // emits subscription.deleted. While now() < this date the user keeps
  // their paid tier; after, `getEffectiveSubscriptionLevelId` returns
  // "free" so we downgrade lazily without a cron job.
  subscriptionEndsAt            DateTime?
  // ── Admin-granted comp tier (Option A from 2026-05-25) ───────────────
  // Lets an admin temporarily grant a higher tier to a user (e.g. comp
  // an influencer to Expert for 30 days) without touching their
  // underlying Stripe subscription. While compTierExpiresAt > now AND
  // compTierLevelId is set, `getEffectiveSubscriptionLevelId` returns
  // the comp tier instead of the paid tier. After expiry, the user
  // reverts silently to whatever their underlying subscription says.
  compTierLevelId               String?
  compTierExpiresAt             DateTime?
  // Audit: when the comp was granted (most recent grant if multiple).
  // A future CompGrant table can replace this with a full log, but
  // for now we just track the latest issue date.
  compTierGrantedAt             DateTime?
  usageCounters                 UsageCounter[]
  // Per-user UI prefs. Currently stores the collapsed state of
  // template-group headers in the editor menu, keyed like
  // `{ "user:Group A": true, "builtin:Group B": false }`. Templates'
  // group field is the source of truth; this just remembers which
  // headers the user wants folded.
  templateGroupPrefs            Json?
  createdAt                     DateTime                   @default(now())
  // Updated (throttled) from the Auth.js jwt callback to power the
  // admin "online / last seen" indicator. Nullable for legacy rows.
  lastSeenAt                    DateTime?
  // The diagram the user is currently viewing — set when a diagram page
  // loads, cleared when they navigate back to the dashboard / a project.
  // Denormalised name avoids a join in the admin Registered Users query.
  currentDiagramId              String?
  currentDiagramName            String?
  // Collaboration Groups (Phase 1) back-relations.
  collaborationGroupsOwned      CollaborationGroup[]       @relation("CollaborationGroupOwner")
  collaborationGroupMemberships CollaborationGroupMember[] @relation("CollaborationGroupMembership")
  collaborationGroupInvitesSent CollaborationGroupMember[] @relation("CollaborationGroupInvitesSent")
  ownershipTransfersFrom        OwnershipTransfer[]        @relation("OwnershipTransferFrom")
  ownershipTransfersTo          OwnershipTransfer[]        @relation("OwnershipTransferTo")
  notifications                 Notification[]
  // Phase 2 — Send for Review back-relations.
  diagramReviewsRequested       DiagramReview[]            @relation("DiagramReviewRequester")
  diagramReviewerEntries        DiagramReviewer[]          @relation("DiagramReviewerUser")
  // Project-sharing back-relations.
  projectShares                 ProjectShare[]             @relation("ProjectShareRecipient")
  diagramsOwned                 Diagram[]                  @relation("DiagramOwner")
  // BPMN lifecycle (Phase 1) back-relations.
  publishedVersionsAuthored     PublishedVersion[]         @relation("PublishedVersionAuthor")
  diagramFeedbackAuthored       DiagramFeedback[]          @relation("DiagramFeedbackAuthor")
  diagramFeedbackResolved       DiagramFeedback[]          @relation("DiagramFeedbackResolver")
  // BPMN lifecycle (Phase 2) back-relations.
  publicationBundlesAuthored    PublicationBundle[]        @relation("PublicationBundleAuthor")
  publicationBundleAudience     PublicationBundleAudience[] @relation("PublicationBundleAudienceMember")
  publicationBundleGrantsMade   PublicationBundleAudience[] @relation("PublicationBundleAudienceAdder")
  pendingBundleInvitesSent      PendingBundleAudience[]    @relation("PendingBundleAudienceInviter")
  // Simulator (Phase 4) — studies this user created.
  simulationStudiesCreated      SimulationStudy[]          @relation("SimulationStudyAuthor")
  // Simulator (Phase 6) — example catalog entries this user authored.
  simulationExamplesCreated     SimulationExample[]        @relation("SimulationExampleAuthor")
  miningExamplesCreated         MiningExample[]            @relation("MiningExampleAuthor")
}

model Project {
  id          String    @id @default(cuid())
  name        String
  description String    @default("")
  ownerName   String    @default("")
  colorConfig Json      @default("{}")
  fontConfig  Json      @default("{}")
  folderTree  Json      @default("{}")
  // APQC PCF association — set when the project is generated/seeded from an
  // APQC framework (L2 folder-seed or a Create-APQC-Process diagram), or
  // chosen in the Project Properties panel. Shape:
  //   { frameworkId, frameworkName, variant, version, rootHierarchyId?, rootName?, seededAt? }
  pcf         Json      @default("{}")
  // When this project was created by adopting a ready-made example, which
  // feature it demonstrates ("simulation" | "mining" | "risk-control"). Drives
  // the feature-coloured dashboard tile. Null for ordinary projects.
  exampleType String?
  // The example this project was adopted from (SimulationExample / MiningExample
  // / RiskControlExample id). Enforces "one copy per user" — re-adopting the same
  // example overwrites this project. Cleared on rename (it becomes the user's own).
  sourceExampleId String?
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Org scoping — required after Phase 0 backfill (scripts/backfill-orgs.ts).
  orgId       String
  org         Org       @relation(fields: [orgId], references: [id], onDelete: Restrict)
  diagrams    Diagram[]
  // Users this project is shared with, plus their role (VIEW / EDIT).
  shares      ProjectShare[]
  // BPMN lifecycle (Phase 2) — bundles published from this project.
  bundles     PublicationBundle[]
  // Entity Lists (External Participants, Org Structure, IT Systems) — a
  // project's own copy, adopted from an org master and edited independently.
  entityLists EntityList[]
  // Risk & Control catalog — project's own copy, adopted from an org master.
  riskControlLibraries RiskControlLibrary[]
  simulationTeams SimulationTeam[]
  simulationCalendars SimulationCalendar[]
  simulationStudies SimulationStudy[]
  processMiningRuns ProcessMiningRun[]
  miningSources     MiningSource[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([orgId])
}

// One row per (project, user) pair the owner has shared the project with.
// Owners never appear here — their ownership is on Project.userId. Recipients
// have either VIEW or EDIT permission. Deleting the Project or the User
// cascades to the share rows.
model ProjectShare {
  id        String           @id @default(cuid())
  projectId String
  project   Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User             @relation("ProjectShareRecipient", fields: [userId], references: [id], onDelete: Cascade)
  role      ProjectShareRole
  createdAt DateTime         @default(now())
  // Owner who added this share. Plain string (no FK) so the audit
  // breadcrumb survives if the granting owner is later deleted.
  createdBy String?

  @@unique([projectId, userId])
  @@index([userId])
}

model Diagram {
  id          String           @id @default(cuid())
  name        String
  type        String           @default("basic")
  data        Json             @default("{}")
  colorConfig Json             @default("{}")
  displayMode String           @default("normal")
  // SuperAdmin "AI Comparison Results": the persisted multi-model generation
  // matrix for this diagram (Opus 4.8 / Sonnet 4.6 / Haiku 4.5 — per-model
  // conformance + the saved per-model diagram IDs). The current diagram's `data`
  // is filled with the Opus 4.8 output. {} = no comparison. A column (not in
  // `data`) so it survives editor save round-trips.
  aiComparison Json            @default("{}")
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId   String?
  project     Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  // Denormalised from Project for query performance — kept in sync by the
  // application layer. Required after Phase 0 backfill.
  orgId       String
  org         Org              @relation(fields: [orgId], references: [id], onDelete: Restrict)
  // Per-diagram accountability label. Defaults to the project owner at
  // creation; mutable by the project owner only (editors and viewers see
  // it read-only). Distinct from the free-text Process Owner inside the
  // DiagramData. SetNull on user delete preserves diagram history with
  // an empty owner slot. Nullable so the field can be added to existing
  // rows without a destructive migration (backfilled by
  // scripts/backfill-project-sharing.ts).
  diagramOwnerId String?
  diagramOwner   User?         @relation("DiagramOwner", fields: [diagramOwnerId], references: [id], onDelete: SetNull)
  history     DiagramHistory[]
  reviews     DiagramReview[]
  // ── BPMN lifecycle (publish + review cadence) ────────────────────────
  // `lifecycle` is the persisted state machine; see DiagramLifecycle enum.
  // `currentPublishedVersionId` points at the latest non-superseded
  // PublishedVersion. Nullable because DRAFT diagrams have none.
  // `nextReviewDate` is owner-set at publish; the cron uses it to fire
  // a `review-due` notification. `reviewCadenceMonths` is convenience —
  // the publish dialog can compute nextReviewDate from this.
  // `lastReviewDueNotifiedAt` is the cron-idempotency guard so re-runs
  // don't spam the owner.
  lifecycle                     DiagramLifecycle    @default(DRAFT)
  currentPublishedVersionId     String?             @unique
  currentPublishedVersion       PublishedVersion?   @relation("DiagramCurrentVersion", fields: [currentPublishedVersionId], references: [id], onDelete: SetNull)
  publishedVersions             PublishedVersion[]  @relation("DiagramAllVersions")
  feedback                      DiagramFeedback[]
  // BPMN lifecycle (Phase 2) — every bundle this diagram is a member of
  // (as a root or pulled in via link closure). Used by the access check
  // and the stale-closure detector.
  bundleMemberships             PublicationBundleDiagram[]
  // Simulator (Phase 4) — studies that pick this diagram as a root.
  simulationStudyRoots          SimulationStudyRoot[]
  nextReviewDate                DateTime?
  reviewCadenceMonths           Int?
  lastReviewDueNotifiedAt       DateTime?
  // ── Process Portal ───────────────────────────────────────────────────
  // "Primary procedure document" — the written SOP that accompanies this
  // process. A URL (SharePoint webUrl or any link) + a display name. Set in
  // Diagram Properties; surfaced read-only in the Portal + /processes viewer.
  procedureDocUrl               String?
  procedureDocName              String?
  // Denormalised from DiagramData.pcf (the diagram-level APQC classification)
  // so the Portal's category facet + search are DB-native — no need to load
  // every diagram's `data` JSON. Synced by the diagram save/publish path;
  // backfilled by scripts/backfill-diagram-pcf.ts.
  pcfId                         Int?
  pcfHierarchyId                String?
  pcfName                       String?
  // Denormalised entity references used by this diagram (pools/lanes/systems),
  // extracted from `data` on every save — an array of { kind, name } (raw
  // labels). The Portal canonicalises these against the Org Entity Lists at
  // read time to power "which processes use System X / involve Team Y".
  entityRefs                    Json               @default("[]")
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([orgId])
  @@index([diagramOwnerId])
  @@index([lifecycle])
  @@index([orgId, lifecycle])
}

model DiagramHistory {
  id        String   @id @default(cuid())
  diagramId String
  diagram   Diagram  @relation(fields: [diagramId], references: [id], onDelete: Cascade)
  snapshot  Json // full diagram data { name, type, data, colorConfig, displayMode }
  userId    String? // who triggered the save (nullable for legacy)
  createdAt DateTime @default(now())

  @@index([diagramId, createdAt])
}

// Immutable per-diagram version snapshot. Created by POST /api/diagrams/[id]/publish.
// Carries no audience — audiences live on PublicationBundle (added in
// Phase 2 of the lifecycle plan). Business users see the latest non-
// superseded version of any diagram they have bundle-granted access to.
model PublishedVersion {
  id            String   @id @default(cuid())
  diagramId     String
  diagram       Diagram  @relation("DiagramAllVersions", fields: [diagramId], references: [id], onDelete: Cascade)
  // Version number per diagram: 1, 2, 3… Auto-incremented by the publish handler.
  versionNumber Int
  publishedAt   DateTime @default(now())
  // Nullable + SetNull so deleting the author doesn't 500 the delete on
  // an FK Restrict (audit DATA-01). The version snapshot is immutable and
  // outlives its author; a null here just means "author account removed".
  publishedById String?
  publishedBy   User?    @relation("PublishedVersionAuthor", fields: [publishedById], references: [id], onDelete: SetNull)
  // Frozen snapshot — mirrors the DiagramHistory columns. Treat as
  // immutable once written.
  name          String
  type          String
  data          Json
  colorConfig   Json
  displayMode   String
  // Owner-supplied notes for this release. Optional.
  releaseNotes  String?
  // When the next version replaces this one, supersededAt is stamped so
  // we can render "v2 (superseded 2026-12-10)" in the version history.
  // Null on the current version.
  supersededAt  DateTime?
  // Snapshot of the nextReviewDate that was in effect at publish time.
  // Kept for audit even after the live Diagram.nextReviewDate moves.
  nextReviewDateAtPublish DateTime?
  // Back-relation for Diagram.currentPublishedVersionId pointing here.
  currentForDiagram Diagram? @relation("DiagramCurrentVersion")
  // Feedback filed against this specific version.
  feedback      DiagramFeedback[]

  @@unique([diagramId, versionNumber])
  @@index([diagramId, publishedAt(sort: Desc)])
}

// Business-user feedback on a published version. Separate from the formal
// review-comment system (DiagramReview/DiagramReviewer) — reviewers are
// internal designers, feedback authors are end-users of the published
// process. Anchored to the version the user was viewing so resolution
// notes against an old version remain meaningful.
//
// `bundleId` (added in Phase 2) records which bundle the user came in
// through. Not present yet because PublicationBundle is added later in
// the same plan.
model DiagramFeedback {
  id                  String           @id @default(cuid())
  diagramId           String
  diagram             Diagram          @relation(fields: [diagramId], references: [id], onDelete: Cascade)
  publishedVersionId  String
  publishedVersion    PublishedVersion @relation(fields: [publishedVersionId], references: [id], onDelete: Cascade)
  // Bundle the author came in through, when known. Useful for the
  // owner's FeedbackPanel ("filed via 'Q4 Operations release'") and
  // for the cross-bundle audience union when several bundles lead to
  // the same diagram. Nullable for legacy / direct-link entries.
  bundleId            String?
  bundle              PublicationBundle? @relation(fields: [bundleId], references: [id], onDelete: SetNull)
  authorId            String
  author              User             @relation("DiagramFeedbackAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  body                String
  // Optional pin to a specific element in the published version's data.
  // The viewer's "attach to element" mode records the element id; the
  // owner's FeedbackPanel uses it to jump to that element on the canvas.
  attachedElementId   String?
  status              FeedbackStatus   @default(OPEN)
  resolvedAt          DateTime?
  resolvedById        String?
  resolvedBy          User?            @relation("DiagramFeedbackResolver", fields: [resolvedById], references: [id], onDelete: SetNull)
  resolutionNote      String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@index([diagramId, status])
  @@index([publishedVersionId])
  @@index([authorId])
}

// A "publish to business users" event. Covers one or more root
// diagrams plus the forward link closure reachable from each via
// element.properties.linkedDiagramId. All members must live in the same
// Project — cross-project bundles aren't supported (see the BPMN
// lifecycle plan for the rationale). Audiences are explicit; users with
// no audience grant via any active bundle have no business-user access.
//
// Bundles do NOT auto-supersede each other. Multiple active bundles can
// overlap in members and audience; access is additive. Owner explicitly
// archives a bundle (sets supersededAt) to revoke its grants.
model PublicationBundle {
  id              String                  @id @default(cuid())
  name            String
  projectId       String
  project         Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  publishedAt     DateTime                @default(now())
  // Nullable + SetNull (audit DATA-01) — a bundle outlives the account
  // that published it. Ownership checks treat null as "not you".
  publishedById   String?
  publishedBy     User?                   @relation("PublicationBundleAuthor", fields: [publishedById], references: [id], onDelete: SetNull)
  releaseNotes    String?
  nextReviewDate  DateTime?
  // Idempotency guard for the review-due cron — see Diagram.lastReviewDueNotifiedAt.
  lastReviewDueNotifiedAt DateTime?
  // Owner archives a bundle to revoke audience grants. Once stamped the
  // access check ignores it. Distinct from per-PublishedVersion supersedure.
  supersededAt    DateTime?
  diagrams        PublicationBundleDiagram[]
  audience        PublicationBundleAudience[]
  pendingAudience PendingBundleAudience[]
  feedback        DiagramFeedback[]

  @@index([projectId])
  @@index([publishedById])
  @@index([supersededAt])
}

// One row per diagram included in a bundle at publish time. `isRoot`
// flags the diagrams the owner explicitly picked as starting points
// (vs. those pulled in via link traversal). The set is frozen at
// publish — to expand it the owner uses the stale-closure flow to
// recompute closure in place (no new bundle row).
model PublicationBundleDiagram {
  id          String            @id @default(cuid())
  bundleId    String
  bundle      PublicationBundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  diagramId   String
  diagram     Diagram           @relation(fields: [diagramId], references: [id], onDelete: Cascade)
  isRoot      Boolean           @default(false)
  addedAt     DateTime          @default(now())

  @@unique([bundleId, diagramId])
  @@index([diagramId])
}

// Per-user audience grant. A business user accessing any diagram in
// the bundle's member set goes through this row. Unique constraint
// prevents double-grants.
model PublicationBundleAudience {
  id          String            @id @default(cuid())
  bundleId    String
  bundle      PublicationBundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  userId      String
  user        User              @relation("PublicationBundleAudienceMember", fields: [userId], references: [id], onDelete: Cascade)
  addedAt     DateTime          @default(now())
  // Nullable + SetNull (audit DATA-01) — attribution of who granted the
  // access; the grant itself survives the granting admin's deletion.
  addedById   String?
  addedBy     User?             @relation("PublicationBundleAudienceAdder", fields: [addedById], references: [id], onDelete: SetNull)

  @@unique([bundleId, userId])
  @@index([userId])
}

// Invite-by-email audience entry. Created when the bundle creator
// invites someone who isn't a registered Diagramatix user yet. The
// invitee gets an email; once they register (or sign in for the first
// time with the matching address) the registration / auth hook promotes
// the pending row into a real PublicationBundleAudience row and deletes
// this one.
//
// Email is stored normalised lowercase so the promotion lookup matches
// regardless of how the inviter typed it. Unique on (bundleId, email)
// stops duplicate invites; the email index lets the promotion hook
// scan in O(log n) when a user signs in.
model PendingBundleAudience {
  id          String            @id @default(cuid())
  bundleId    String
  bundle      PublicationBundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  email       String
  invitedAt   DateTime          @default(now())
  // Nullable + SetNull (audit DATA-01) — attribution of who sent the
  // invite; the pending invite survives the inviter's deletion.
  invitedById String?
  invitedBy   User?             @relation("PendingBundleAudienceInviter", fields: [invitedById], references: [id], onDelete: SetNull)

  @@unique([bundleId, email])
  @@index([email])
}

model DiagramTemplate {
  id           String   @id @default(cuid())
  name         String
  diagramType  String   @default("bpmn")
  templateType String   @default("user")
  // Free-form group name. Null = ungrouped. Same name across multiple
  // templates clusters them under one collapsible header in the editor
  // menu. User and builtin clusters are independent (user-template
  // "Patterns" and builtin-template "Patterns" are two separate groups).
  group        String?
  data         Json     @default("{}")
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Prompt {
  id            String    @id @default(cuid())
  name          String
  text          String
  diagramType   String    @default("bpmn")
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  orgId         String
  org           Org       @relation(fields: [orgId], references: [id], onDelete: Restrict)
  // Last edited 2-phase AI Plan for this prompt (AiElement[] + AiConnection[]).
  // null until the user saves with a plan present.
  planJson      Json?
  planUpdatedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([orgId])
  @@index([userId, diagramType])
}

model DiagramRules {
  id        String   @id @default(cuid())
  category  String // "general", "bpmn", "state-machine", "value-chain", "domain", "context", "process-context"
  rules     String // multiline text — numbered rules in groups
  isDefault Boolean  @default(false) // true = admin-set system default
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orgId     String?
  org       Org?     @relation(fields: [orgId], references: [id], onDelete: Restrict)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([category, userId, orgId]) // one set of rules per category per user per org
}

// BPMN Scanner rule registry — SuperAdmin-managed lifecycle layered over the
// code-defined checks in diagramChecks.ts. A row here either OVERRIDES a code
// rule (same `code`) or is a brand-new proposed rule. Rows are never hard-
// deleted (status -> "retired") so a retired rule's number is never reused.
//   status: "proposed"       — new/changed, not yet implemented in code ([PROPOSED])
//           "live"           — implemented in code
//           "pending-delete" — flagged for removal, awaiting code removal ([PENDING])
//           "retired"        — removal confirmed; kept only to reserve its number
model ScannerRule {
  code        String   @id // "B33"
  title       String
  description String
  severity    String   @default("warning") // "error" | "warning"
  category    String   @default("custom")
  status      String   @default("proposed")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ────────────────────────────────────────────────────────────────────────────
// Subscriptions — four real tiers (Free / Introductory / Professional /
// Expert) plus a derived "Administration" view for SUPERUSER_EMAILS users
// (never stored as a row, never enforces limits).
//
// SubscriptionLevel rows are seeded with the canonical limits but editable
// by admins via /dashboard/admin/subscriptions. Limit columns are nullable
// where null = unlimited.
//
// UsageCounter tracks event metrics (AI attempts, exports, imports) keyed
// by (userId, periodKey, metric). periodKey is "YYYY-MM" for monthly
// resetting counters and "all-time" for Free's lifetime counters.
// Point-in-time metrics (project count, diagram count, archimate total,
// element counts) are computed from the actual tables and don't need a
// UsageCounter row.
// ────────────────────────────────────────────────────────────────────────────

model SubscriptionLevel {
  id           String @id // "free" | "introductory" | "professional" | "expert"
  name         String // display name
  priceMonthly Int    @default(0) // AUD cents
  sortOrder    Int // for UI ordering

  // Limits. null = unlimited.
  maxProjects                   Int?
  maxDiagramsPerTypePerProject  Int?
  maxArchimateDiagramsTotal     Int?
  maxNonBpmnElementsPerDiagram  Int?
  maxBpmnElementsPerDiagram     Int?
  maxAiAttempts                 Int?
  aiAttemptsResetMonthly        Boolean @default(true) // false → lifetime counter (Free)
  maxIndividualExports          Int?
  individualExportsResetMonthly Boolean @default(true)
  maxIndividualImports          Int?
  individualImportsResetMonthly Boolean @default(true)
  maxBulkExports                Int?
  maxBulkImports                Int?
  // Days from subscriptionAssignedAt before the tier expires and the
  // user is soft-blocked from any further creation / AI / export /
  // import action. Null = no expiry (the default for paid tiers).
  // Free is seeded with 30.
  trialDays                     Int?

  // Stripe Price ID linking this tier to a recurring price in Stripe.
  // Null for Free (no payment). Set once via the admin Subscriptions
  // editor (or a seed script) after creating the matching Product +
  // Price in the Stripe dashboard. The Checkout flow looks this up by
  // tier ID and refuses to start if it's missing for a paid tier.
  stripePriceId String?

  // Per-tier feature entitlements — SuperAdmin allocates which major features
  // a tier includes (dashboard/admin/subscriptions editor). When false, the
  // feature's launch buttons + example galleries are hidden, the OrgAdmin tile
  // is greyed, and the entry API routes return 403. Default true so no existing
  // user loses access on migration; SuperAdmin then restricts per tier.
  // riskControl covers BOTH the Risk-Control Matrix and Compliance Monitoring.
  hasSimulator     Boolean @default(true)
  hasProcessMining Boolean @default(true)
  hasRiskControl   Boolean @default(true)
  hasApqc          Boolean @default(true)

  users     User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UsageCounter {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  periodKey String // "2026-05" | "all-time"
  metric    String // "ai_attempts" | "individual_exports" | "individual_imports" | "bulk_exports" | "bulk_imports"
  count     Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([userId, periodKey, metric])
  @@index([userId])
}

// ────────────────────────────────────────────────────────────────────────────
// Feature catalog — admin-editable, two-stage (draft + published).
//
// Admin edits the `name` / `summary` / `details` / `hidden` / `sortOrder`
// fields freely. They show up in the admin editor only. The dashboard
// "Features" modal AND the public /features marketing page read the
// `published*` mirror fields exclusively. Clicking "Publish All" in
// the admin editor copies draft → published in one transaction.
//
// `details` is markdown — typically a list of 3-5 bullets per feature.
// Stored as one string so the editor stays simple (no per-bullet rows).
// ────────────────────────────────────────────────────────────────────────────

model Feature {
  id        String @id @default(cuid())
  sortOrder Int    @default(0)

  // Draft fields — only admins see these.
  name    String
  summary String
  details String
  hidden  Boolean @default(false)

  // Published snapshot — what the marketing page + dashboard show.
  // Null = never published yet.
  publishedName      String?
  publishedSummary   String?
  publishedDetails   String?
  publishedHidden    Boolean?
  publishedSortOrder Int?
  publishedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Admin-editable per-diagram-type bubble-help cards. Each row binds a
// code-level trigger (`topicKey`, e.g. "create-connector",
// "select-multiple") to the human-readable text shown in the cloud and
// the duration the cloud stays visible. `conditionLabel` is purely
// descriptive — it lets admins remember what each topic key fires on
// (e.g. "Click on an Element"). One set per diagramType — global
// across all users / diagrams of that type.
model BubbleHelp {
  id             String   @id @default(cuid())
  diagramType    String
  topicKey       String
  conditionLabel String
  text           String
  durationMs     Int      @default(10000)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([diagramType, topicKey])
  @@index([diagramType])
}

// Admin-editable per-diagram-type visual identity: a 2-character badge
// code + a pastel colour pair (background/text). Drives the project
// nav-tree badge, the editor top bar tint + type pill, and the
// diagram-type chips across the app. One row per diagram type; SuperAdmin
// maintains them at /dashboard/admin/diagram-types. Static defaults live
// in app/lib/diagram/diagramTypeStyles.ts and are used when a row is
// absent, so the table is purely an override layer.
model DiagramTypeStyle {
  id        String   @id @default(cuid())
  typeKey   String   @unique // "bpmn" | "context" | "process-context" | …
  code      String   // 2-char badge code, e.g. "BP"
  bgColor   String   // pastel background hex, e.g. "#dbeafe"
  textColor String   // foreground hex, e.g. "#1d4ed8"
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ────────────────────────────────────────────────────────────────────────────
// Collaboration Groups + in-app Notifications (Phase 1 of the Collaboration
// Groups feature). Phase 2 adds DiagramReview / DiagramReviewer; Phase 3
// adds the connector-kind columns. See plan in
// `.claude/plans/nifty-singing-hennessy.md`.
// ────────────────────────────────────────────────────────────────────────────

// Minimal in-app notification inbox. Polled from the dashboard bell.
// `type` is a string discriminator (kept loose so Phases 2 + 3 can add
// new event types without a schema bump); `payload` is the type-specific
// JSON used by the bell popover to render the link / row.
model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  payload   Json
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

model CollaborationGroup {
  id         String   @id @default(cuid())
  name       String
  ownerId    String
  owner      User     @relation("CollaborationGroupOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  // When set, this is the auto-created Org-wide group. Org Owner is
  // the group's owner; deletion / rename are forbidden in v1.
  orgId      String?
  org        Org?     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  isOrgGroup Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  members   CollaborationGroupMember[]
  transfers OwnershipTransfer[]
  reviews   DiagramReview[]

  @@index([ownerId])
  @@index([orgId])
}

model CollaborationGroupMember {
  id          String             @id @default(cuid())
  groupId     String
  group       CollaborationGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId      String
  user        User               @relation("CollaborationGroupMembership", fields: [userId], references: [id], onDelete: Cascade)
  // "invited" | "accepted" | "declined" | "left" | "removed"
  status      String
  invitedAt   DateTime           @default(now())
  joinedAt    DateTime?
  invitedById String?
  invitedBy   User?              @relation("CollaborationGroupInvitesSent", fields: [invitedById], references: [id], onDelete: SetNull)

  @@unique([groupId, userId])
  @@index([userId, status])
}

// Phase 2 — Send for Review. One DiagramReview per (diagram, group) the
// owner sends to; one DiagramReviewer per assigned reviewer within it.
// Both feed the virtual "Diagrams Sent / Received for Review" projects —
// membership is derived from these rows, not Diagram.projectId.
model DiagramReview {
  id          String          @id @default(cuid())
  diagramId   String
  diagram     Diagram         @relation(fields: [diagramId], references: [id], onDelete: Cascade)
  groupId     String
  group       CollaborationGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  requesterId String
  requester   User            @relation("DiagramReviewRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  objective   String
  dueDate     DateTime
  // "open" | "resubmitted" | "closed"
  status      String          @default("open")
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  reviewers   DiagramReviewer[]

  @@index([diagramId])
  @@index([groupId])
  @@index([requesterId])
}

model DiagramReviewer {
  id             String        @id @default(cuid())
  reviewId       String
  review         DiagramReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  userId         String
  user           User          @relation("DiagramReviewerUser", fields: [userId], references: [id], onDelete: Cascade)
  // "pending" | "in-progress" | "submitted" | "approved" | "declined-to-review"
  status         String        @default("pending")
  lastActivityAt DateTime?

  @@unique([reviewId, userId])
  @@index([userId, status])
}

model OwnershipTransfer {
  id         String             @id @default(cuid())
  groupId    String
  group      CollaborationGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  fromUserId String
  fromUser   User               @relation("OwnershipTransferFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUserId   String
  toUser     User               @relation("OwnershipTransferTo", fields: [toUserId], references: [id], onDelete: Cascade)
  // "pending" | "accepted" | "declined" | "cancelled"
  status     String             @default("pending")
  createdAt  DateTime           @default(now())
  resolvedAt DateTime?

  @@index([toUserId, status])
  @@index([groupId, status])
}

// ────────────────────────────────────────────────────────────────────────────
// Entity Lists — governed name sources for BPMN pools/lanes.
//   • Participant  : flat list of External Participant (non-IT black-box) names
//   • System       : flat list of IT System (System black-box) names
//   • OrgStructure : hierarchy Organisation → OrgUnit → Team → Role
// An Org holds a master library; a Project adopts a COPY it edits independently.
// ────────────────────────────────────────────────────────────────────────────
enum EntityListKind {
  Participant
  System
  OrgStructure
  Document
  DataStore
}

enum EntityNodeLevel {
  Participant
  System
  Organisation
  OrgUnit
  Team
  Role
  Document
  DataStore
}

// A named, org-allocated Entity Structure bundles the (up to) five lists an org
// governs — Organisational Hierarchy (OrgStructure) + External Participants
// (Participant) + IT Systems (System) + Documents + Data Stores. `orgId` IS the
// allocation: SuperAdmin creates a structure for an org; that org's OrgAdmin may
// edit it; projects in the org adopt a copy of it.
model EntityStructure {
  id        String       @id @default(cuid())
  name      String
  orgId     String
  org       Org          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  lists     EntityList[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([orgId])
}

model EntityList {
  id           String           @id @default(cuid())
  name         String
  kind         EntityListKind
  // Exactly one of orgId / projectId is set.
  orgId        String?
  org          Org?             @relation(fields: [orgId], references: [id], onDelete: Cascade)
  projectId    String?
  project      Project?         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  // The named Entity Structure this list belongs to (org masters). Null for
  // legacy / ungrouped lists and for project copies.
  structureId  String?
  structure    EntityStructure? @relation(fields: [structureId], references: [id], onDelete: Cascade)
  // The org master this project copy was cloned from (provenance only).
  sourceListId String?
  sourceList   EntityList?      @relation("EntityListClone", fields: [sourceListId], references: [id], onDelete: SetNull)
  clones       EntityList[]     @relation("EntityListClone")
  nodes        EntityNode[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([orgId, kind])
  @@index([projectId, kind])
  @@index([structureId])
}

model EntityNode {
  id        String          @id @default(cuid())
  listId    String
  list      EntityList      @relation(fields: [listId], references: [id], onDelete: Cascade)
  // null for flat lists and for the top of a hierarchy.
  parentId  String?
  parent    EntityNode?     @relation("EntityNodeTree", fields: [parentId], references: [id], onDelete: Cascade)
  children  EntityNode[]    @relation("EntityNodeTree")
  name      String
  level     EntityNodeLevel
  sortOrder Int             @default(0)
  // Document-kind items may link to a SharePoint file. Stored as scalar columns
  // (not JSON) to sidestep the Prisma 7 JSON-write caveat; mirrors the
  // element.properties.sharepointLink shape { driveId, itemId, name, webUrl }.
  spDriveId String?
  spItemId  String?
  spName    String?
  spWebUrl  String?
  // Provenance on a PROJECT COPY node → the master node it was cloned from. Null
  // on masters AND on project-local additions. Drives "Sync updates" (soft
  // pointer, no FK: a master node may be deleted and Sync reconciles).
  sourceNodeId String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([listId, parentId, sortOrder])
  @@index([sourceNodeId])
}

// ────────────────────────────────────────────────────────────────────────────
// Risk & Control catalog — a governed library of Risks and Controls attached to
// process steps to produce a Risk-Control Matrix (RCM) + coverage checks.
// An Org holds a master library; a Project adopts a COPY it edits independently
// (mirrors Entity Lists). Controls MITIGATE Risks via RiskControlLink.
// ────────────────────────────────────────────────────────────────────────────
// A GRC library item kind. Risk + Control are the RCM core; the rest form the
// wider governance/traceability graph (a step ↔ risk ↔ control ↔ policy ↔
// regulation ↔ audit finding, with KRIs/KPIs as indicators).
enum RiskControlKind {
  Risk
  Control
  Policy
  Regulation
  AuditFinding
  KRI
  KPI
}

enum ControlType {
  Preventive
  Detective
  Corrective
}

enum ControlAutomation {
  Manual
  Automated
  ITDependent
}

model RiskControlLibrary {
  id             String              @id @default(cuid())
  name           String
  // Exactly one of orgId / projectId is set.
  orgId          String?
  org            Org?                @relation(fields: [orgId], references: [id], onDelete: Cascade)
  projectId      String?
  project        Project?            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  // The org master this project copy was cloned from (provenance only).
  sourceLibraryId String?
  sourceLibrary  RiskControlLibrary? @relation("RiskControlLibraryClone", fields: [sourceLibraryId], references: [id], onDelete: SetNull)
  clones         RiskControlLibrary[] @relation("RiskControlLibraryClone")
  items          RiskControlItem[]
  links          RiskControlLink[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([orgId])
  @@index([projectId])
}

model RiskControlItem {
  id           String             @id @default(cuid())
  libraryId    String
  library      RiskControlLibrary @relation(fields: [libraryId], references: [id], onDelete: Cascade)
  kind         RiskControlKind
  code         String             // short handle, e.g. "R-01" / "C-01"
  name         String
  description  String?
  sortOrder    Int                @default(0)
  // Risk attributes (kind = Risk)
  likelihood         Int?         // 1..5 (inherent)
  impact             Int?         // 1..5 (inherent)
  riskCategory       String?
  residualLikelihood Int?         // 1..5 (after controls)
  residualImpact     Int?         // 1..5 (after controls)
  // Control attributes (kind = Control)
  controlType  ControlType?
  automation   ControlAutomation? // Manual | Automated | IT-dependent
  frequency    String?            // how often the control runs
  owner        String?
  frameworkRef String?            // e.g. "SOX 404", "ISO 27001 A.9"
  // Audit / assurance
  evidence     String?            // what evidence proves the control operated
  testMethod   String?            // how internal audit tests it
  testFrequency String?           // how often it is tested
  // Operating effectiveness from mining: the conformance-deviation signature this
  // control guards against (e.g. "undocumented-transition|In Progress|Ready to Pay").
  // When that deviation appears in the project's mining conformance, the control
  // was "bypassed" in that many cases.
  monitorSignature String?
  // Directed traceability edges where this item is the source / the target.
  // (Control→Risk = mitigates; Policy→Control = governs; Regulation→Policy =
  //  requires; AuditFinding→Control = addresses; KRI→Risk = monitors; …)
  linksOut     RiskControlLink[]  @relation("LinkSource")
  linksIn      RiskControlLink[]  @relation("LinkTarget")
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([libraryId, kind, sortOrder])
}

// Org-scoped RCM code counter — codes (R-001, C-001, …) are numbered org-wide,
// one running sequence per (org, kind), so a code is unique across ALL of an
// org's projects. Incremented atomically when a new item is minted; the
// renumber action seeds it to the current max. `counter` = last number assigned.
model RiskControlCodeSequence {
  id      String          @id @default(cuid())
  orgId   String
  kind    RiskControlKind
  counter Int             @default(0)

  @@unique([orgId, kind])
}

// ── APQC Process Classification Framework (PCF) ──────────────────────────────
// Standalone feature (NOT Entity Lists). Two layers: read-only global reference
// frameworks (imported from the APQC workbooks) and org-owned tailored
// frameworks composed/extended/curated from them. pcfId is APQC's stable id and
// is the key everything (classification refs + tailored provenance) hangs off,
// so tags survive version bumps.
model PcfFramework {
  id              String    @id @default(cuid())
  orgId           String?   // null = global reference; set = org's (imported reference or tailored)
  org             Org?      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  kind            String    // "reference" | "tailored"
  familyKey       String    // stable variant identity: "cross-industry" | "telecom" | tailored cuid
  name            String
  variant         String    // "Cross-Industry" | "Retail" | …
  version         String    // "8.0" | "7.21" | tailored rev
  isCurrent       Boolean   @default(true)
  sourceKNumber   String?   // provenance of the source workbook, e.g. "K09276"
  division        String?   // tailored only — optional business-unit scope
  attributionNote String    @default("") // ©APQC notice — travels with copies/exports
  nodes           PcfNode[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([orgId])
  @@index([familyKey, isCurrent])
}

model PcfNode {
  id               String    @id @default(cuid())
  frameworkId      String
  framework        PcfFramework @relation(fields: [frameworkId], references: [id], onDelete: Cascade)
  pcfId            Int       // APQC col A — STABLE across releases (the upgrade key)
  hierarchyId      String    // dotted code col B — display only, NOT stable
  name             String
  description      String?
  level            Int
  parentId         String?
  parent           PcfNode?  @relation("PcfTree", fields: [parentId], references: [id], onDelete: Cascade)
  children         PcfNode[] @relation("PcfTree")
  sortOrder        Int       @default(0)
  metricsAvailable Boolean   @default(false) // flag only, never OSB values
  changeType       String?   // "NEW" | "RENAMED" from the workbook's Change Details
  // tailored-layer fields:
  isCustom         Boolean   @default(false)
  active           Boolean   @default(true)
  orgCode          String?
  sourceFrameworkId String?  // provenance: reference framework a composed node came from
  sourcePcfId      Int?      // provenance: the APQC pcfId it was composed from

  @@index([frameworkId, parentId, sortOrder])
  @@index([frameworkId, hierarchyId])
  @@index([sourcePcfId])
}

model RiskControlLink {
  id         String             @id @default(cuid())
  libraryId  String
  library    RiskControlLibrary @relation(fields: [libraryId], references: [id], onDelete: Cascade)
  sourceId   String
  source     RiskControlItem    @relation("LinkSource", fields: [sourceId], references: [id], onDelete: Cascade)
  targetId   String
  target     RiskControlItem    @relation("LinkTarget", fields: [targetId], references: [id], onDelete: Cascade)
  createdAt  DateTime           @default(now())

  @@unique([sourceId, targetId])
  @@index([libraryId])
}

// ────────────────────────────────────────────────────────────────────────────
// Simulation — a shared team (resource pool) the process Simulator draws on.
// Mirrors the EntityList org-master → project-copy pattern: exactly one of
// orgId / projectId is set; sourceTeamId tracks the org master a project copy
// was cloned from. capacity is the pool size N (what makes queues form).
// ────────────────────────────────────────────────────────────────────────────
model SimulationTeam {
  id           String   @id @default(cuid())
  name         String
  orgId        String?
  org          Org?     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  projectId    String?
  project      Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceTeamId String?
  sourceTeam   SimulationTeam?  @relation("SimulationTeamClone", fields: [sourceTeamId], references: [id], onDelete: SetNull)
  clones       SimulationTeam[] @relation("SimulationTeamClone")
  capacity     Int      @default(1)
  costPerHour  Float?
  efficiency   Float    @default(1.0)
  calendar     Json     @default("{}")
  // Working hours: id of the SimulationCalendar this team follows (a plain id
  // reference, not an FK, so a deleted calendar just falls back to always-open).
  calendarId   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([orgId])
  @@index([projectId])
}

// ────────────────────────────────────────────────────────────────────────────
// Simulation — a reusable weekly working calendar (a team's shift pattern or a
// source's operating hours). Mirrors SimulationTeam's org-master → project-copy
// shape. `pattern` holds a WorkCalendar (app/lib/simulation/types.ts): a set of
// open windows { day, start "HH:MM", end "HH:MM", rate? }; anything uncovered is
// closed. t=0 in the sim clock is anchored to Monday 00:00.
// ────────────────────────────────────────────────────────────────────────────
model SimulationCalendar {
  id             String   @id @default(cuid())
  name           String
  orgId          String?
  org            Org?     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  projectId      String?
  project        Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceCalendarId String?
  sourceCalendar SimulationCalendar?  @relation("SimulationCalendarClone", fields: [sourceCalendarId], references: [id], onDelete: SetNull)
  clones         SimulationCalendar[] @relation("SimulationCalendarClone")
  pattern        Json     @default("{\"intervals\":[]}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([orgId])
  @@index([projectId])
}

// ────────────────────────────────────────────────────────────────────────────
// Process Mining — one ingested event log + its discovered artefacts. Mirrors
// SimulationStudy's project/org scoping. The raw log isn't stored; `variants`
// holds the compressed log (distinct entity behaviours + frequency) which is
// enough to (re)run discovery/conformance/calibration. Discovered BPMN + state-
// machine diagrams and the calibrated SimulationStudy are referenced by id.
// ────────────────────────────────────────────────────────────────────────────
model ProcessMiningRun {
  id               String   @id @default(cuid())
  name             String
  orgId            String?
  org              Org?     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  projectId        String?
  project          Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdById      String?
  mapping          Json     @default("{}")   // column → role
  stats            Json     @default("{}")   // headline aggregates
  variants         Json     @default("[]")   // compressed log
  performance      Json     @default("{}")   // timing/resource aggregates (simulator feed)
  governance       Json?                      // {controls,risks,policies} mined from Control/Risk/Policy IDs on events
  discoveredBpmnId String?                    // Diagram id
  discoveredSmId   String?                    // Diagram id
  referenceSmId    String?                    // Diagram id (user-selected)
  conformance      Json?                      // {fitness, violations[], transitionStats}
  studyId          String?                    // SimulationStudy id (calibrated twin)
  // OCEL study grouping — an object-centric OCEL import mines one run per object
  // type, tied together by ocelGroupId and to the shared Domain Diagram.
  ocelGroupId      String?                    // groups the per-object-type runs of one OCEL import
  objectType       String?                    // the OCEL object type this run's lifecycle is for
  domainDiagramId  String?                    // the shared Domain Diagram (object model backbone)
  // Excluded from org Compliance Monitoring — a throwaway/test run the OrgAdmin
  // (or run owner) doesn't want polluting the effectiveness trend. Default false.
  excludeFromCompliance Boolean @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([orgId])
  @@index([projectId])
}

// A live event-ingestion source (Phase 1 connectors) — pushes (webhook) or pulls
// (watched folder) events that keep one "live" ProcessMiningRun refreshed in
// place. Buffer is a windowed accumulation of normalised rows (capped at
// maxEvents); config/cursor drive pull sources. The webhook key is stored as a
// sha256 hash only (raw shown once). See app/lib/mining/refreshRun.ts.
model MiningSource {
  id            String   @id @default(cuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  orgId         String?
  createdById   String?
  name          String
  kind          String   // "webhook" | "azure-blob" | "sharepoint"
  apiKeyHash    String?  // sha256 hex of the webhook key
  apiKeyPrefix  String?  // first 8 chars, for display
  mapping       Json     @default("{}")   // LogMapping: incoming field → role
  config        Json     @default("{}")   // { blobListUrl } | { driveId, itemId, folderPath, folderName }
  cursor        Json     @default("{}")   // watermark for pull: { lastModified, seenNames[] }
  buffer        Json     @default("[]")   // windowed accumulated event rows (capped)
  headerFields  Json     @default("[]")   // stable column order for buildEventLog
  runId         String?  // the live ProcessMiningRun this source maintains
  maxEvents     Int      @default(100000)
  autoRefresh   Boolean  @default(true)
  lastIngestAt  DateTime?
  lastRefreshAt DateTime?
  eventCount    Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([projectId])
  @@index([kind])
}

// A simulation Study (the portfolio) — a named set of root diagrams whose
// forward-link closure the engine assembles into one process network. Mirrors
// PublicationBundle / PublicationBundleDiagram: project-scoped, the root set
// frozen as join rows, the closure recomputed at assembly time.
model SimulationStudy {
  id          String                @id @default(cuid())
  name        String
  projectId   String
  project     Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  // Nullable + SetNull (audit DATA-01) — the study outlives its author.
  createdById String?
  createdBy   User?                 @relation("SimulationStudyAuthor", fields: [createdById], references: [id], onDelete: SetNull)
  roots       SimulationStudyRoot[]
  scenarios   SimulationScenario[]
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([projectId])
  @@index([createdById])
}

// One row per root diagram the study expands. The engine walks each root's
// forward-link closure at assembly; the stored set is just the picked roots.
model SimulationStudyRoot {
  id        String          @id @default(cuid())
  studyId   String
  study     SimulationStudy @relation(fields: [studyId], references: [id], onDelete: Cascade)
  diagramId String
  diagram   Diagram         @relation(fields: [diagramId], references: [id], onDelete: Cascade)
  addedAt   DateTime        @default(now())

  @@unique([studyId, diagramId])
  @@index([diagramId])
}

// A what-if scenario inside a study (≙ BPSim Scenario). `runConfig` is the
// SimRunConfig + planned interventions; `overrides` is the sparse OverrideSet
// deep-merged over the assembled baseline (≙ BPSim `Scenario inherits`).
// `status` is DRAFT | QUEUED | RUNNING | DONE | FAILED (String, not a DB enum,
// so adding states stays a code change, not a migration).
model SimulationScenario {
  id         String          @id @default(cuid())
  name       String
  studyId    String
  study      SimulationStudy @relation(fields: [studyId], references: [id], onDelete: Cascade)
  isBaseline Boolean         @default(false)
  runConfig  Json            @default("{}")
  overrides  Json            @default("{}")
  // Optional process VARIANT: diagram ids this scenario runs instead of the
  // study's roots — the basis of As-is vs To-be comparison (each scenario can
  // run a structurally different diagram). Empty array = inherit study roots.
  variantRootIds Json        @default("[]")
  status     String          @default("DRAFT")
  runs       SimulationRun[]
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([studyId])
}

// An editable, extensible catalog entry: a worked example simulation a
// simulation master can adopt into their own project to learn from. A global
// catalog (not org/project-scoped) mirroring the Feature catalog — admins
// CRUD entries, `published` gates visibility, `package` (JSON) holds the
// portable bundle (annotated diagrams + team library + study + scenarios).
// A seed populates the starter set; admins author more by capturing a project.
model SimulationExample {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  concept     String   @default("")    // one-line tagline (the lesson)
  description String   @default("")     // markdown walkthrough
  difficulty  String   @default("core") // intro | core | advanced
  sortOrder   Int      @default(0)
  published   Boolean  @default(false)
  package     Json     @default("{}")
  createdById String?
  createdBy   User?    @relation("SimulationExampleAuthor", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([published, sortOrder])
}

// An editable, extensible catalog entry for DiagramatixMINER: a worked process-
// mining example a user can adopt into their own project. Mirrors
// SimulationExample (global catalog, `published` gates visibility) — `package`
// (JSON) holds the portable bundle: a compressed event log (mapping + variants
// + performance + stats) plus reference state-machine diagrams. Adopt recreates
// a ready ProcessMiningRun + the reference diagrams in a fresh project; the
// seed populates the starter set; admins author more by capturing a run.
model MiningExample {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  concept     String   @default("")     // one-line tagline (the lesson)
  description String   @default("")      // markdown walkthrough
  difficulty  String   @default("core")  // intro | core | advanced
  sortOrder   Int      @default(0)
  published   Boolean  @default(false)
  package     Json     @default("{}")
  createdById String?
  createdBy   User?    @relation("MiningExampleAuthor", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([published, sortOrder])
}

// Risk & Control (GRC) example catalog — global, adoptable in one click into a
// fresh project: process diagrams + a GRC library (risks/controls/policies/…)
// attached to steps + an optional mining run for control effectiveness. Mirrors
// MiningExample. `package` (JSON) holds the whole adoptable bundle.
model RiskControlExample {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  concept     String   @default("")
  description String   @default("")
  difficulty  String   @default("core")
  sortOrder   Int      @default(0)
  published   Boolean  @default(false)
  package     Json     @default("{}")
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([published, sortOrder])
}

// One execution of a scenario — run history for comparison. Snapshots the
// resolved config + assembled network so a run reproduces even if the model
// later changes; `metrics` holds the aggregated results.
model SimulationRun {
  id              String             @id @default(cuid())
  scenarioId      String
  scenario        SimulationScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  configSnapshot  Json               @default("{}")
  networkSnapshot Json               @default("{}")
  metrics         Json               @default("{}")
  error           String?
  // Run History: a user-given name (e.g. "Large Sales Team (25)") pins the run
  // into the browsable history; unnamed/unpinned runs are pruned to the last few
  // per scenario. `pinned` is set true whenever a run is named.
  name            String?
  pinned          Boolean            @default(false)
  startedAt       DateTime           @default(now())
  finishedAt      DateTime?

  @@index([scenarioId])
}

// ────────────────────────────────────────────────────────────────────────────
// User Guide — the in-app help, migrated out of hardcoded JSX so SuperAdmins can
// edit it in-app. Content is stored as Markdown (GFM) per section; rendered to
// sanitised HTML at view time. `adminOnly` drives the 2-way audience model (a
// SuperAdmin-only chapter/section is hidden from User/OrgAdmin viewers).
// ────────────────────────────────────────────────────────────────────────────
model HelpChapter {
  id         String        @id @default(cuid())
  slug       String
  collection String        @default("user-guide")   // "user-guide" (the in-app help) | "tech-design" (SuperAdmin design notes)
  title      String
  category   String?        // optional grouping for the searchable/filterable viewer (e.g. "Diagram Types", "AI Generation"); null = ungrouped
  sortOrder  Int           @default(0)
  adminOnly  Boolean       @default(false)
  sections   HelpSection[]
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@unique([collection, slug])
  @@index([collection, sortOrder])
}

model HelpSection {
  id           String      @id @default(cuid())
  chapterId    String
  chapter      HelpChapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  collection   String      @default("user-guide")   // denormalised from the chapter so the PUT's scoped delete needs no join
  heading      String?
  bodyMarkdown String      @db.Text
  adminOnly    Boolean     @default(false)
  image        String?
  imageAlt     String?
  imageCaption String?
  sortOrder    Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([chapterId, sortOrder])
}

// Captured screenshots for the User Guide. Bytes live in the DB (the container's
// public/ is read-only at runtime), served by GET /api/help/images/[id]. Named by
// the screen and (if a diagram screen) the diagram. Authored via the global
// SuperAdmin capture tool; referenced from a HelpSection.image as /api/help/images/<id>.
model HelpImage {
  id          String   @id @default(cuid())
  filename    String
  screenName  String
  diagramName String?
  alt         String?
  mimeType    String   @default("image/png")
  bytes       Bytes
  width       Int?
  height      Int?
  // Author's userId — plain field, no FK (audit hint that survives user deletion).
  createdById String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

// ────────────────────────────────────────────────────────────────────────────
// Global key-value application settings (SuperAdmin-tunable, single row per key).
// First use: "ai.generate.model" = the Claude model AI Generate uses. Kept
// generic so future one-off system settings don't each need a new table.
// ────────────────────────────────────────────────────────────────────────────
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// Runtime Diagram-JSON validation findings (parallel Zod validator). App-side
// observability only — NOT part of the diagram export/DDL, so it does NOT bump
// SCHEMA_VERSION. One row per DISTINCT problem (deduped by `signature` = route +
// issue path + id-normalised message); repeats bump `count` + `lastSeen`.
model SchemaValidationIssue {
  id            String   @id @default(cuid())
  signature     String   @unique
  route         String
  diagramId     String?
  schemaVersion String?
  path          String
  message       String   @db.Text
  count         Int      @default(1)
  resolved      Boolean  @default(false)
  firstSeen     DateTime @default(now())
  lastSeen      DateTime @updatedAt

  @@index([resolved, lastSeen])
}
