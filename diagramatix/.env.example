# Diagramatix — environment variables reference.
#
# Copy this file to `.env` (local dev) and fill in real values. In
# production these are sourced from Azure Key Vault and surfaced as App
# Service application settings — never committed.
#
# `.gitignore` and `.dockerignore` both keep `.env*` out of the repo /
# image; only this `.env.example` is whitelisted.

# ── Database ──────────────────────────────────────────────────────────────
# Local dev: postgres on localhost. Production (Azure PG Flex Server)
# requires `?sslmode=require` on the connection string.
DATABASE_URL="postgres://postgres:postgres@localhost:5432/diagramatix"

# ── Auth.js (next-auth v5 beta) ───────────────────────────────────────────
# AUTH_SECRET signs the JWTs. Generate a fresh value with:
#   openssl rand -base64 32
# A weak or shared secret silently lets anyone forge a session, so rotate
# this whenever you suspect leakage.
AUTH_SECRET="replace-with-openssl-rand-base64-32-output"

# Required when the app sits behind a reverse proxy (Next.js standalone
# in a container behind Azure App Service). Without this, Auth.js
# discards X-Forwarded-* headers and the OAuth callback URL falls back
# to http://localhost.
AUTH_TRUST_HOST=true

# Session lifetime (seconds). Optional — defaults to a 7-day absolute cap with a
# daily rolling refresh. Tighten for enterprise (e.g. 28800 = 8h) via env.
# AUTH_SESSION_MAX_AGE=604800
# AUTH_SESSION_UPDATE_AGE=86400

# Full origin the browser hits. Used for OAuth callback URLs and email
# verification links. Local: http://localhost:3000. Production:
# https://app.diagramatix.com.au
NEXTAUTH_URL="http://localhost:3000"

# ── Microsoft Entra ID (Azure AD) — SharePoint integration ────────────────
# Register an App in the Entra portal:
#   Sign-in: single tenant, redirect URI matches NEXTAUTH_URL +
#   `/api/auth/callback/microsoft-entra-id`. Grant `Files.ReadWrite.All`
#   and `Sites.Read.All` with admin consent. Copy IDs and a client
#   secret value (NOT the secret ID) below. Secrets expire — calendar
#   the rotation date you set when creating the secret.
AZURE_CLIENT_ID="00000000-0000-0000-0000-000000000000"
AZURE_CLIENT_SECRET="replace-with-entra-client-secret-value"
AZURE_TENANT_ID="00000000-0000-0000-0000-000000000000"

# ── Admin elevation password ──────────────────────────────────────────────
# Optional. Allows non-superuser callers to create built-in templates by
# supplying this value in the request body. Superusers (listed in
# SUPERUSER_EMAILS) don't need it. Empty / unset = elevation disabled.
ADMIN_PASSWORD="replace-with-something-only-the-admin-knows"

# ── SMTP — password reset emails ──────────────────────────────────────────
# Diagramatix sends from a Microsoft 365 mailbox on diagramatix.com.au.
# The mailbox must have "Authenticated SMTP" enabled in the Exchange admin
# centre (Users → mailbox → Mail → Manage email apps → tick Authenticated
# SMTP). If MFA is enforced on the mailbox, generate an app password at
# aka.ms/MFASetup and use that as SMTP_PASS instead of the real password.
#
# Office 365 SMTP relay: smtp.office365.com on port 587 with STARTTLS
# (SMTP_SECURE=false — STARTTLS is negotiated mid-session, not implicit).
SMTP_HOST="smtp.office365.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="support@diagramatix.com.au"
SMTP_PASS="replace-with-mailbox-or-app-password"
SMTP_FROM="support@diagramatix.com.au"

# ── Anthropic Claude API — AI-assisted BPMN generation ────────────────────
# Get a key at https://console.anthropic.com → Settings → API Keys.
# Workspace keys are preferred over personal keys (scoped billing).
ANTHROPIC_API_KEY="sk-ant-api03-replace-with-real-key"
# Optional — route ALL Claude traffic through an enterprise proxy / private
# gateway / region-pinned or self-hosted endpoint (data-residency + egress
# control). Leave unset to use Anthropic's default endpoint (api.anthropic.com).
# ANTHROPIC_BASE_URL="https://your-gateway.example.com"
# Optional — retain the raw prompt text in the SuperAdmin model-comparison result
# (Diagram.aiComparison). Off by default (only the prompt length is kept) so
# customer prompt content isn't persisted. Set to 1 to keep the text for debugging.
# AI_COMPARE_STORE_PROMPT=1

# ── Deepgram — real-time voice dictation in the AI panels ──────────────────
# Get a key at https://console.deepgram.com → API Keys (Member/Owner key).
# The server mints a short-lived temp key per session so the browser streams
# straight to Deepgram without seeing this master key. If unset, dictation
# falls back to the browser's built-in speech engine.
DEEPGRAM_API_KEY=""

# ── Stripe — self-serve subscriptions ─────────────────────────────────────
# Test keys come from Stripe Dashboard → Developers → API Keys with the
# Test Mode toggle ON. Webhook secret is from Developers → Webhooks →
# (your endpoint) → Reveal signing secret, OR from `stripe listen` output
# during local dev (starts with `whsec_`). NEXT_PUBLIC_ key is safe to
# expose to the browser — that's the publishable key, not the secret.
# Flip these to live-mode counterparts (sk_live_*, pk_live_*, separate
# whsec_) for the production rollout step.
STRIPE_SECRET_KEY="sk_test_replace-with-real-key"
STRIPE_WEBHOOK_SECRET="whsec_replace-after-running-stripe-listen-or-creating-endpoint"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_replace-with-real-key"
