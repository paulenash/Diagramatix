# Build context exclusions for the production Docker image.
#
# Everything not needed inside the image — either because it's regenerated
# during the build (node_modules, .next, prisma client output) or because
# it would leak local state / secrets / dev tooling (.env*, .git, IDE
# files, OS metadata, logs). Mirrors .gitignore plus the patterns specific
# to the multi-stage Dockerfile.
#
# Anything explicitly NEEDED inside the image (public/, prisma/, etc.) is
# NOT listed here.

# ── Dependencies (re-installed by the `deps` stage) ────────────────────────
node_modules
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Build outputs (re-generated by the `builder` stage) ────────────────────
.next
out
build
*.tsbuildinfo

# ── Prisma client output (re-generated by `npx prisma generate` in deps) ──
# Keeping a stale dev-machine copy out of the build context guarantees the
# image's client matches the schema in the COMMIT, not whatever was on the
# author's laptop.
app/generated

# ── Env files — secrets must come from Key Vault at runtime, never bake ──
.env
.env.*
!.env.example

# ── Git / VCS metadata ─────────────────────────────────────────────────────
.git
.gitignore
.gitattributes

# ── CI / CD config (not needed inside the image) ───────────────────────────
.github

# ── Docker artefacts ───────────────────────────────────────────────────────
Dockerfile
.dockerignore
docker-compose*.yml

# ── Testing / coverage ─────────────────────────────────────────────────────
coverage
.nyc_output
test-results
playwright-report

# ── IDE / editor config ────────────────────────────────────────────────────
.vscode
.idea
*.swp
*.swo
*.code-workspace

# ── OS metadata ────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Logs / debug ───────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Markdown docs — not served at runtime, not imported by any route. ─────
# (README.md and similar live in version control, not in the image.)
*.md

# ── Vercel / Netlify ───────────────────────────────────────────────────────
.vercel
.netlify

# ── Local data + ad-hoc scripts (build-time tooling only) ──────────────────
# scripts/ contains the marker-fix CJS scripts (fix-terminate-marker etc.)
# that patch the v1.5 template — run locally when adjusting stencils, not
# at runtime.
scripts

# ── Database dumps / backup files generated by /api/backup and the admin
#    Full Backup UI. These are user data, never part of an image. ──────────
*.sql
*.dump
*.diag
*.diag-full
*.bak

# ── PostgreSQL local data dir (if Paul ever runs PG inside the project) ────
pgdata
postgres-data

# ── Claude / agent metadata (never relevant to the build) ──────────────────
.claude
.cursor

# ── Miscellaneous ──────────────────────────────────────────────────────────
*.pem
*.key
*.cer
*.pfx
