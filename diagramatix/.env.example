# Diagramatix — environment variables reference.
#
# Copy this file to `.env` (local dev) and fill in real values. In
# production these are sourced from Azure Key Vault and surfaced as App
# Service application settings — never committed.
#
# `.gitignore` and `.dockerignore` both keep `.env*` out of the repo /
# image; only this `.env.example` is whitelisted.

# ── Database ──────────────────────────────────────────────────────────────
# Local dev: postgres on localhost. Production (Azure PG Flex Server)
# requires `?sslmode=require` on the connection string.
DATABASE_URL="postgres://postgres:postgres@localhost:5432/diagramatix"

# ── Auth.js (next-auth v5 beta) ───────────────────────────────────────────
# AUTH_SECRET signs the JWTs. Generate a fresh value with:
#   openssl rand -base64 32
# A weak or shared secret silently lets anyone forge a session, so rotate
# this whenever you suspect leakage.
AUTH_SECRET="replace-with-openssl-rand-base64-32-output"

# Required when the app sits behind a reverse proxy (Next.js standalone
# in a container behind Azure App Service). Without this, Auth.js
# discards X-Forwarded-* headers and the OAuth callback URL falls back
# to http://localhost.
AUTH_TRUST_HOST=true

# Full origin the browser hits. Used for OAuth callback URLs and email
# verification links. Local: http://localhost:3000. Production:
# https://app.diagramatix.com.au
NEXTAUTH_URL="http://localhost:3000"

# ── Microsoft Entra ID (Azure AD) — SharePoint integration ────────────────
# Register an App in the Entra portal:
#   Sign-in: single tenant, redirect URI matches NEXTAUTH_URL +
#   `/api/auth/callback/microsoft-entra-id`. Grant `Files.ReadWrite.All`
#   and `Sites.Read.All` with admin consent. Copy IDs and a client
#   secret value (NOT the secret ID) below. Secrets expire — calendar
#   the rotation date you set when creating the secret.
AZURE_CLIENT_ID="00000000-0000-0000-0000-000000000000"
AZURE_CLIENT_SECRET="replace-with-entra-client-secret-value"
AZURE_TENANT_ID="00000000-0000-0000-0000-000000000000"

# ── SMTP — password reset emails ──────────────────────────────────────────
# Local dev typically uses a Gmail account with an app-specific password
# (16 lowercase letters, no spaces). Production will switch to Azure
# Communication Services Email; the env vars stay the same shape — only
# SMTP_HOST and credentials change.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="noreply@example.com"
SMTP_PASS="replace-with-app-specific-password"
SMTP_FROM="noreply@example.com"

# ── Anthropic Claude API — AI-assisted BPMN generation ────────────────────
# Get a key at https://console.anthropic.com → Settings → API Keys.
# Workspace keys are preferred over personal keys (scoped billing).
ANTHROPIC_API_KEY="sk-ant-api03-replace-with-real-key"
