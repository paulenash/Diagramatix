<?xml version="1.0" encoding="UTF-8"?>
<!--
  Diagramatix Export Schema
  Namespace: http://diagramatix.com/export/1.0

  Two version numbers are tracked:
    schemaVersion (major.minor) — the export data structure version.
      Only bumped when fields are added, removed, or renamed.
      Major bump = breaking change; minor bump = additive (new optional fields).
    appVersion (major.minor.build) — the Diagramatix application version.
      Build number = git commit count; changes every commit.

  The xs:schema version attribute carries the schemaVersion.
  The appVersion is recorded as an annotation below and injected at runtime via /api/schema.

  WHEN TO BUMP schemaVersion: ONLY when the data structure actually changes —
  either this XSD / the Diagram JSON export shape, OR the physical database as
  described by the Logical DDL (app/lib/diagram/ddlGenerate.ts). The version number
  tracks the persisted data structure; if neither the export shape nor the DDL
  changes, DO NOT bump it (feature-only releases ride the current version).

  MAINTENANCE — these FOUR must always be kept in sync, and move together on a bump:
    1. app/lib/diagram/types.ts   — the SCHEMA_VERSION constant + its history comment
    2. this XSD                   — the shape + the history block below
    3. app/lib/diagram/ddlGenerate.ts — the Logical DDL (physical DB structure)
    4. schema/SCHEMA_CHANGELOG.md — the human-readable changelog (table + detail)

  v1.10 — round-trip serialisation completeness bump.
    No schema shape change. The v1.9 fields below were declared in this
    XSD but the XML serialiser previously dropped them; they are now
    emitted and parsed faithfully:
      <dgx:data>      attributes "poolFontSize", "laneFontSize", "database"
      <dgx:connector> attribute  "bottleneck"
    See SCHEMA_VERSION history in app/lib/diagram/types.ts for the
    behavioural changes shipped in this release (Task/Sub-Process Name
    + autosize, Pool/Lane grow-only, Visio bulk import, scan for issues,
    Deleted Diagrams hierarchy, etc.) — none of which alter the data
    shape, so the XSD is unchanged below.

  v1.11 — template groups.
    No project-export schema shape change. Templates are not carried in
    this XSD's <diagramatix-export> bundle; the new `DiagramTemplate.group`
    field is serialised in `.diag_tems` template-export files and in
    the `/api/backup` user-backup payload (both JSON, not covered by
    this XSD). The `schemaVersion` attribute below is bumped to 1.11
    so consumers can detect the new feature window even if no
    project-XML field changed.

  v1.12 — subscriptions.
    No project-export schema shape change. Subscriptions are user-level
    metadata (SubscriptionLevel rows + User.subscriptionLevelId +
    User.subscriptionAssignedAt + UsageCounter rows) and are never
    embedded in a diagram or project export. The schemaVersion attribute
    is bumped to 1.12 so importers can detect the new feature window.

  v1.13 — subscriptions phase 2 foundation (Stripe wiring).
    No project-export schema shape change. New User columns
    (stripeCustomerId, stripeSubscriptionId, stripeSubscriptionStatus,
    currentPeriodEnd, subscriptionEndsAt) plus
    SubscriptionLevel.stripePriceId are user-level / catalog metadata
    only — never embedded in a diagram or project export. Same release
    also covers the Visio v1.6 stencil (fresh BaseID GUIDs vs v1.5),
    focus-edit zoom on label edits, and the Pool/Lane "Label" → "Name"
    rename. The schemaVersion attribute is bumped to 1.13 so importers
    and the User Guide reflect the new feature window.

  v1.14 — Bubble Help v2 + Diagram Properties restructure.
    Adds one new optional element to <dgx:data>:
      <dgx:processOwner name="…" email="…"/>
    Both attributes optional. Pre-v1.14 exports omit the element;
    importers treat it as no owner. Bubble Help itself is admin-
    managed catalog data (per-diagramType rows in the BubbleHelp
    Prisma table) and is NOT embedded in diagram exports.

  v1.15 — Collaboration & Review (Phases 1-3).
    Two additive enum members, both round-tripped as ordinary diagram
    content:
      SymbolTypeEnum    + "review-comment"      (a reviewer's pink note;
                                                  element.properties carries
                                                  reviewId / reviewerId /
                                                  reviewerName / reviewerEmail)
      ConnectorTypeEnum + "review-comment-link"  (pink link note -> element)
    The rest of the feature — Collaboration Groups, DiagramReview /
    DiagramReviewer, Notifications — is relational metadata and is NOT
    embedded in a diagram or project export. Pre-v1.15 exports simply
    contain neither enum value.

  v1.16 — BPMN right-click picker + editor polish. No schema shape
    change; both GatewayTypeEnum and GatewayRoleEnum already existed.
    The bump documents three behavioural changes worth knowing about
    when comparing exports across versions:
      - The gateway right-click "type-picker" now exposes both
        gatewayType (None / Exclusive / Inclusive / Parallel /
        Event-based) AND properties.gatewayRole (Decision / Merge) in
        a single multi-section menu. Pre-v1.16 the user could only
        set gatewayRole via the Properties panel.
      - The intermediate-event right-click Trigger list no longer
        offers "Terminate" — BPMN reserves the terminate trigger for
        end events only. Exports that already carry eventType =
        "terminate" on an intermediate-event remain readable (the
        schema still allows the enum value); the change is purely
        in the picker UI.
      - Intermediate events get a second right-click section,
        "Flow Type" (None / Catching / Throwing), writing to the
        existing top-level FlowTypeEnum-typed flowType attribute.
      - Properties-panel label "Element" renamed to "Gateway Type"
        for consistency with the right-click section header.
      - Four additive diagram-check rules in the shared rule registry
        (Scan Diagrams for Issues / Diagram Scan for Issues): every
        Activity must have an incoming AND outgoing sequence connector
        (errors; event sub-processes and process-scope expanded subs
        exempt); sequence connectors with 4+ bends are flagged as
        warnings and highlighted orange on the canvas; Task/Sub-Process
        type should match its message flows (Send to / Receive from a
        non-IT pool; User for any flow to or from an IT system pool).
        No XSD shape change — these rules read existing fields only.
      - Sub-process right-click picker gets a second section, "Repeat"
        (None / Loop / MI Sequential / MI Parallel), writing to the
        existing top-level RepeatTypeEnum-typed repeatType attribute.
      - Two ad-hoc-aware rules and matching changes to the activity
        flow-connectivity rules:
          * adhoc-ep-no-start-end (error): an Expanded Sub-Process
            marked Ad-Hoc must not contain or boundary-mount Start or
            End events.
          * adhoc-ep-no-sequence-between-children (error): an Ad-Hoc
            EP must not have sequence connectors between its child
            activities.
          * activity-no-incoming / activity-no-outgoing are now
            EP-aware: activities inside an ad-hoc EP are never flagged,
            and inside a non-ad-hoc EP one orphan per EP is allowed
            (the entry/exit activity). Two or more orphans of either
            kind in a non-ad-hoc EP are errors.
      - Scan-highlight connector overlay (Review Mode) no longer draws
        an orange line through the centre of the source/target element
        — the invisible-leader waypoints at element centres are
        excluded from the overlay polyline.
      - Two new data-artefact rules (warnings):
          * data-object-no-association: a Data Object with no
            association connector.
          * data-store-no-association: a Data Store with no
            association connector.

  v1.17 — Independent Context-Diagram "Process Names" font size +
    behaviour batch (AI Generate rules, BPMN scanner overhaul, image
    attachments, UI restructure). ONE shape change below:
      <dgx:data> gains an optional attribute `processFontSize`
        (xs:decimal). Carries the Context-Diagram process-system
        label size independently from entity labels (`fontSize`),
        connector labels (`connectorFontSize`) and title
        (`titleFontSize`). Default 16 when omitted. Pre-1.17 exports
        omit the attribute and importers fall back to the default.
    Behaviour-only changes shipped under the same bump:
      * Context Diagram AI Generate now code-enforces C3.* (process
        radius cap, entity-face spread, ≥20 px cluster spacing on the
        process circle, label stagger). Endpoint nudge wraps around
        corners and travels the full circumference of circles.
        Upper-left-quadrant attachment pile-up fixed by wrapping the
        cluster's procAngle to (-π, π] before the side check.
      * Per-Context font controls: Entity Names / Process Names /
        Flow Labels with their own defaults. Properties label header
        reads "Name" for entities and processes; "Label" for flow
        connectors.
      * Process Context AI Generate enforces P2.08 (actor spacing),
        P2.09 (no use-case → use-case associations), P2.10 (actor
        groups centred on the boundary midpoint) and P2.11 (use-case
        ellipses auto-grown to fit the wrapped label while preserving
        aspect ratio). The hardcoded "P-XX-NN" process-numbering
        instruction is removed from the prompt.
      * BPMN scanner rule registry gains stable codes B01..B31. Flat
        viewer at /dashboard/admin/scanner-rules. B14 rewritten as a
        per-Task trigger matrix (message direction × pool kind);
        B28 absorbed into B14; B22 removed; B19 narrowed to
        INCOMING; B23..B27 added for boundary start / intermediate
        routing; B29 sequence-clips-own-endpoint and B30
        sequence-clips-foreign-node added (with circle / diamond
        body exemptions); B31 manual-task-no-it-system-message
        added.
      * BPMN AI Generate accepts image attachments (PNG / JPEG /
        WebP / GIF). Sonnet vision reverse-engineers the BPMN
        plan from a diagram screenshot or translates a flowchart.
        Two-phase pipeline lets the user edit the plan JSON before
        applying layout.
      * bpmnLayout's messageBPMN emission now writes 4 waypoints
        (centre, srcEdge, tgtEdge, centre) and sets
        sourceInvisibleLeader / targetInvisibleLeader true so
        AI-generated message flows are body-draggable out of the
        box. messageBPMN body drag: select the flow and grab
        anywhere on the highlighted line to slide horizontally; the
        blue midpoint handle is gone.
      * "Create Prompt from Diagram" red admin block on every
        AI-Generate panel (BPMN PlanPanel + non-BPMN AiPanel):
        Technical Description (deterministic walker) and Staff
        Narrative (Sonnet rewrite under an editable briefing stored
        as DiagramRules category "staff-narrative").
      * AI Plan Formats viewer covers every diagram type via a type
        selector. Per-diagram-type "AI Rules & Preferences —
        <Type>" admin link in the Diagram menu opens
        /dashboard/rules?category=<slug>. Sidebar hides in scoped
        mode.
      * Admin link moved from the System / File menu to the leftmost
        menu item on Dashboard, Project and Diagram screens.
      * Matrix screensaver toggle moved to the bottom-left.
      * Notification dropdown wider with two visible lines.

  v1.18 — SuperAdmin / OrgAdmin reorg + messageBPMN label rule + Project
    tile right-click menu. No schema shape change — all-behavioural.
      * messageBPMN labels now anchor to the SOURCE attachment point
        (Paul's rule, Scenario 4). When the source pool moves or its
        source-side boundary moves the label moves rigidly with the
        source endpoint; when only the target side moves the label
        stays put. Replaces the earlier nearest-endpoint heuristic
        across MOVE_ELEMENT, MOVE_ELEMENTS and RESIZE_ELEMENT paths.
      * Black-box pool bottom-edge engagement fixed — a click on the
        boundary of a black-box pool now starts a RESIZE on the first
        attempt instead of needing a prior body-drag to "wake up" the
        resize tracker.
      * Project tile destructive actions moved to a right-click
        context menu with three tiers: x (delete project, diagrams
        → Unorganised; Owner/OrgAdmin/SuperAdmin), x+ (delete
        project, diagrams → Archive; OrgAdmin only), x++ (hard delete
        project + every diagram; SuperAdmin AND project Owner only).
        Inline icon buttons collapse to just clone (⧉).
      * Role colours: SuperAdmin entry points + actions are now RED;
        OrgAdmin remains orange. Updated across every chip, header
        and admin nav link.
      * SuperAdmin admin pages renamed from "Admin —" to plain
        "Registered Users" (vSCHEMA.COMMIT version tag); per-page back
        link styled as a blue hyperlink with the destination word
        underlined, dynamic label (Dashboard / SuperAdmin / OrgAdmin
        / Project / Diagram) honouring `?from=` everywhere.
      * Bubble Help editor migrated from the right-side Diagram
        Properties panel to /dashboard/admin/bubble-help with its
        own diagram-type dropdown and Save+Cancel both disabled
        until the row list diverges from the last persisted snapshot.
      * BPMN Scanner Rules link moved from the BPMN diagram menu to
        the SuperAdmin nav, renamed "BPMN Scanner Rules". Per-
        diagram-type "AI Rules & Preferences — BPMN Process"
        shortcut removed from the diagram menu entirely.
      * Registered Users table: sortable + filterable per column
        (Name, Email Address, Status, Subscription, Registered);
        Subscription pill shows trial days remaining for Free; Org
        Role column collapsed to display-only (role flips happen
        on the Org Settings page).
      * OrgAdmin landing page at /dashboard/org-admin replaces the
        three-chip cluster on the dashboard header with a single
        "OrgAdmin" chip that opens a menu of three cards
        (Registered Users, Org Settings, Project Sharing). Each
        card carries `?from=/dashboard/org-admin` so the back link
        on the destination page reads "← OrgAdmin".
      * Entity Type removed from the Org Settings UI (schema field
        retained with default "Other" for forward-compat). Org
        Settings Danger Zone Delete Org no longer guards on
        subscription tier — SuperAdmin can delete any non-last Org.
      * New BPMN scan rule B32 — Pool / Lane labels must fit within
        the rotated header region. New AI generate rule R7.05 —
        black-box pool names use Shift-Enter on word boundaries so
        the rotated header stays compact.
      * Connector-drag auto-scrolls the canvas when the cursor
        approaches a viewport edge mid-creation; rubber-band line
        stays attached to the cursor across pan updates by reading
        the pan/zoom refs each tick.
      * Diagram Issues popup is now draggable; canvas is visible
        behind it instead of overlay-dimmed.
      * Save / Cancel pattern made dirty-aware across editors:
        Bubble Help, Subscriptions, Features Catalog, Rules Editor.
        Save and Cancel both disable until in-memory state diverges
        from the last persisted snapshot; re-disable after save.

  v1.19 — Audit Stage-2 data-integrity fixes. No schema shape change.
    Backend/restore only: author-attribution FKs made nullable + SET NULL;
    full backup now captures + restores every model; wipe-restore breaks
    the Diagram↔PublishedVersion FK cycle. None of these touch the
    diagram/project export shape.

  v1.20 — Audit Stage-3 engine fixes. No schema shape change. Undo/redo
    now preserves title/fonts/database/processOwner/parentDiagramIds (so a
    round-tripped export is unaffected by an undo); DELETE_ELEMENT cleans up
    connectors on a removed host's boundary events; property setters clear
    the stale redo branch. All behavioural.

  v1.21 — Diagram-type identity + backup preview/streaming + restore
    hardening. No schema shape change. Per-type 2-char codes + pastel
    colours live in the admin-managed DiagramTypeStyle table (NOT embedded
    in an export); backups gain a pre-flight preview, member/Org selection
    and live streaming progress; user + rules/prompts restores are now
    transactional. The schemaVersion attribute is bumped to 1.21 so
    importers and the User Guide reflect the new feature window even though
    no project-XML field changed.

  v1.22 — SharePoint/OneDrive integration. Data Objects / Data Stores may
    carry a `sharepointLink` (the linked file's metadata). Additive optional
    field on data elements; older exports remain valid.

  v1.23 — Entity Lists (governed name sources for BPMN pools/lanes:
    External Participants, IT Systems, and an Organisation → Org Unit →
    Team → Role hierarchy, maintained at Org and Project level). No
    project-XML field changed — pools/lanes still carry a plain label;
    the names are simply drawn from a project's adopted/created structure.
    schemaVersion bumped to 1.23 so importers and the User Guide reflect
    the new feature window (same convention as v1.21).

  v1.24 — BPMN process Simulator (BPSim-aligned discrete-event simulation).
    Per-element baseline simulation parameters (arrival / cycle / wait
    distributions, team + resource units, loop / multi-instance, event
    triggers, token property assignments) ride OPAQUELY in
    element.properties.sim — the open PropertiesType already permits this,
    so no enumerated schema change. The decision-branch routing fields were
    added to the Connector data model but the diagram XML/XSD export was
    left unchanged at 1.24 (deferred to 1.25). Teams, studies, scenarios and
    runs are application database tables, not part of the diagram export.

  v1.25 — Simulation connector fields now SERIALISED in the diagram XML
    export. A <dgx:connector> may carry the decision-gateway branch routing as
    optional attributes: branchProbability (0..100), branchCondition (an
    expression), isDefaultFlow (the else edge). Previously in-model only —
    emitted now, the same way the v1.10 fix restored `bottleneck`. Additive +
    optional; older exports remain valid; export-only (no importer change).
    (The matching DDL-generator columns + User-Guide/Features notes follow as a
    separate update.)

  v1.26 — Application metadata only: DiagramData gains optional `aiFeedback`
    (the AI's open questions + the user's answers, for a clarification round).
    Lives in the saved JSON, not the BPMN XML interchange — no XSD shape change.

  v1.27 — DB-backed User Guide (in-app SuperAdmin editor), an image library
    (screen capture + upload), global voice dictation, Save & View, Markdown
    export, SharePoint documents, and a table-level User Guide backup/restore
    (content + the whole image library, ids preserved). Application/admin
    features only — the diagram data structure and this XSD are UNCHANGED; the
    version attribute advances with the release window (same convention as
    v1.10 / v1.21).

  v1.28 — BPMN layout-geometry rules: Start/End event placement + connector
    length (R8.14/R8.15/R8.18), element de-overlap (R8.17), event-label nudge
    (R8.16); new scanner checks B33/B34/B35 (event-label / element / lane
    overlap); a lane-tiling re-stack fix and an EP boundary-resize drift fix.
    Layout, validation and editor-interaction only — the diagram data structure
    and this XSD are UNCHANGED; the version attribute advances with the release
    window (same convention as v1.27).

  v1.29 — Simulation results & comparison: a true per-case flow-time distribution
    (Typical p50 / Near-worst p95 / Spread + a distribution histogram) in place of
    run-average percentiles; a grounded AI assessment of an As-is/To-be comparison
    (deltas computed deterministically, then written up by the model); a browsable
    Run History (name/pin runs, prune the unpinned, compare any two saved runs);
    and As-is/To-be comparison carried through the example catalogue (variant
    scenarios survive capture/adopt) with a seeded Aardwolf Loans comparison.
    Simulation runtime, results and example-catalogue only — the diagram data
    structure and this XSD are UNCHANGED; the version attribute advances with the
    release window (same convention as v1.27 / v1.28).

  v1.30 — Simulator resource calendars / working hours: a project-level Calendar
    library (reusable weekly shift patterns — open windows per weekday with an
    optional per-window arrival-rate multiplier for time-varying demand). Teams are
    staffed only during their calendar's open windows; arrival sources only generate
    when open. A source event may carry an OPTIONAL string `calendarId` inside
    element.properties.sim (referencing a project calendar) — the open PropertiesType
    already permits it, so this XSD's structure is UNCHANGED (as with the v1.24 sim
    params). New runtime DB tables (SimulationCalendar, SimulationTeam.calendarId)
    are not part of the diagram export. The version attribute advances with the
    release window.

  v1.31 — DiagramatixMINER (Process Mining): ingest event logs → discover the
    implied BPMN + a candidate State-Machine, check state-change conformance vs a
    reference State-Machine, and calibrate a simulation "digital twin" from the
    mined data. Discovered artefacts are ordinary bpmn/state-machine diagrams; the
    new ProcessMiningRun runtime table is not part of the diagram export. This
    XSD's structure is UNCHANGED; the version attribute advances with the release
    window.

  v1.32 — DiagramatixMINER Examples: an adoptable process-mining sample catalog
    (new MiningExample runtime table; one-click "Load & open" recreates a ready
    ProcessMiningRun + reference State-Machine diagrams in a fresh project). The
    reference diagrams are ordinary state-machine diagrams; the catalog table is
    not part of the diagram export. This XSD's structure is UNCHANGED; the
    version attribute advances with the release window.

  v1.33 — Risk & Control: a step may carry an OPTIONAL `risk` object inside
    element.properties ({ riskRefs[], controlRefs[] } — each a catalog item id +
    cached code/label), the ONLY diagram-export change — the open PropertiesType
    already permits it, so this XSD's structure is UNCHANGED (as with the v1.24
    sim params and v1.30 calendarId). New runtime DB tables (RiskControlLibrary,
    RiskControlItem, RiskControlLink — an org master adopted into a project copy)
    are not part of the diagram export. The version attribute advances with the
    release window.

  v1.34 — DiagramatixMINER standards + Technical Design Notes + Logical DDL.
    No diagram-export shape change — this XSD's structure is UNCHANGED; the version
    advances with the release window. (1) The process miner now accepts logs with
    no State column (an Activity→State table completes the lifecycle), reads
    Control/Risk/Policy IDs off events into a governance aggregate, and imports/
    exports IEEE XES (1849) and OCEL 2.0/1.0 alongside CSV — none of which touch
    the diagram export. (2) A SuperAdmin "Technical Design Notes" document + Word
    .docx export (application feature; DB tables HelpChapter/HelpSection gain a
    `collection` discriminator). (3) The Diagramatix DDL generator is relabelled
    "Logical DDL Generation". All runtime/app — the diagram bundle is untouched.

  v1.35 — APQC Process Classification Framework (PCF). SHAPE CHANGE: a new
    OPTIONAL top-level <pcfAttribution> element on the export root (between
    <project> and <diagrams>), carrying APQC's verbatim ©notice — emitted whenever
    the export contains PCF-derived content (a diagram classification or an element
    tagged with a pcfId). APQC's royalty-free licence requires the notice to travel
    with every copy/derivative. Diagrams may also carry an OPTIONAL DiagramData.pcf
    classification and element.properties.pcfHierarchyId/pcfId (open PropertiesType,
    unchanged). New runtime tables PcfFramework + PcfNode and a Project.pcf column
    are not part of the diagram export.

  v1.36 — Primary procedure document. SHAPE CHANGE: a new OPTIONAL <procedureDoc>
    element on DiagramDataType (after <processOwner>) — the written SOP linked to a
    process, with a required url and an optional name. Runtime-only (NOT in the
    export): the Process Portal (org-wide search/browse of published processes,
    entity where-used search, admin-managed "My Teams") and the review-due reminder
    cron; their Diagram denorm columns (procedureDoc*/pcf*/entityRefs) are derived
    from data and are not part of the diagram export.

  v1.37 — Import competitor BPMN diagrams as-is. SHAPE CHANGE: a new OPTIONAL
    boolean relaxedLayout attribute on <data> (emitted only when true) — "free-form
    / imported layout": pools may be any size/placement (not stacked full-width),
    message flows route rectilinearly between non-aligned elements, and the
    pure-geometry validation rules are suppressed. AI image import can additionally
    reproduce a vendor's drawn positions + connector attachment/routing (normalised
    bounds/waypoints are plan-only — NOT part of the export).

  v1.38 — Domain (UML) diagram elements + connectors. SHAPE CHANGE: SymbolTypeEnum
    gains "uml-package" and "uml-note"; ConnectorTypeEnum gains "uml-containment"
    (a solid DIRECT package-to-package line ending in a circle-with-cross marker;
    an OPTIONAL boolean connector attribute containmentSwapEnd moves that marker
    from the target end to the source end) and "uml-note-anchor" (a dashed DIRECT
    arrowhead-less Note->element link). Both reuse the existing "direct" routingType.
    Behaviour-only (no shape change): a "Direct" straight-line option on
    uml-generalisation and Shift near-edge quick-add of class attributes/operations.
    (These enum + attribute declarations were synced into this XSD retroactively
    during the schema-changelog catch-up; the release itself was v1.38.)

  v1.39 — Pain Points. SHAPE CHANGE: SymbolTypeEnum gains "uml-pain-point" (an
    auto-numbered starburst icon — the number is the element label; the OPTIONAL
    multi-line properties.description rides in the open PropertiesType) and <data>
    gains an OPTIONAL boolean showPainPointDescriptions (auto-enabled with the first
    Pain Point). Behaviour-only: auto-connect on element drop restricted to BPMN /
    flowchart. (uml-pain-point synced into this XSD retroactively; release v1.39.)

  v1.40 — Pain Point "Display Pain Points" master toggle. SHAPE CHANGE: <data> gains
    an OPTIONAL boolean showPainPoints (absent or true = icons shown; explicit false
    = hidden); the v1.39 showPainPointDescriptions toggle nests under it.
-->

<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema"
           xmlns:dgx="http://diagramatix.com/export/1.0"
           targetNamespace="http://diagramatix.com/export/1.0"
           elementFormDefault="qualified"
           version="{{SCHEMA_VERSION}}">

  <xs:annotation>
    <xs:documentation>Generated by Diagramatix {{APP_VERSION}}</xs:documentation>
  </xs:annotation>

  <!-- ============================================================ -->
  <!-- Version patterns                                              -->
  <!-- ============================================================ -->
  <!-- Schema version: major.minor  e.g. "1.0", "1.1", "2.0" -->
  <xs:simpleType name="SchemaVersionString">
    <xs:restriction base="xs:string">
      <xs:pattern value="\d+\.\d+"/>
    </xs:restriction>
  </xs:simpleType>

  <!-- App version: major.minor.build  e.g. "1.0.147" -->
  <xs:simpleType name="AppVersionString">
    <xs:restriction base="xs:string">
      <xs:pattern value="\d+\.\d+\.\d+"/>
    </xs:restriction>
  </xs:simpleType>

  <!-- ============================================================ -->
  <!-- Root element                                                  -->
  <!-- ============================================================ -->
  <xs:element name="diagramatix-export" type="dgx:ExportType"/>

  <xs:complexType name="ExportType">
    <xs:sequence>
      <xs:element name="project"        type="dgx:ProjectType"/>
      <!-- APQC PCF attribution notice — present whenever the export carries
           PCF-derived content (a classification or a pcf-tagged element). -->
      <xs:element name="pcfAttribution" type="xs:string" minOccurs="0"/>
      <xs:element name="diagrams"       type="dgx:DiagramListType"/>
      <xs:element name="folderTree"     type="dgx:FolderTreeType" minOccurs="0"/>
    </xs:sequence>
    <xs:attribute name="schemaVersion" type="dgx:SchemaVersionString" use="required"/>
    <xs:attribute name="appVersion"    type="dgx:AppVersionString"    use="required"/>
    <xs:attribute name="exportedAt"    type="xs:dateTime"             use="required"/>
  </xs:complexType>

  <!-- ============================================================ -->
  <!-- Project metadata                                              -->
  <!-- ============================================================ -->
  <xs:complexType name="ProjectType">
    <xs:sequence>
      <xs:element name="name"        type="xs:string"/>
      <xs:element name="description" type="xs:string"  minOccurs="0"/>
      <xs:element name="ownerName"   type="xs:string"  minOccurs="0"/>
      <xs:element name="colorConfig" type="dgx:ColorConfigType" minOccurs="0"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="ColorConfigType">
    <xs:sequence>
      <xs:any processContents="lax" minOccurs="0" maxOccurs="unbounded"/>
    </xs:sequence>
