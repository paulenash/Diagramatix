      <textAnnotation id="sid-0B598F34-7A59-47CB-823D-284EC8FF58CA" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            <signavio:signavioMetaData metaKey="meta-refnumber" metaValue="[]"/>
            <signavio:signavioLabel bold="" fill="#ff0000" fontFamily="" fontSize="" italic="" ref="text-left"/>
            <signavio:signavioLabel bold="" fill="#ff0000" fontFamily="" fontSize="" italic="" ref="text-right"/>
         </extensionElements>
         <text>Where is the Care Worker Profile created?
From which system? Manually?</text>
      </textAnnotation>
      <textAnnotation id="sid-477788A1-4F05-4BE2-A74F-8B804DFAD1C1" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            <signavio:signavioMetaData metaKey="meta-refnumber" metaValue="[]"/>
            <signavio:signavioLabel bold="" fill="#ff0000" fontFamily="" fontSize="" italic="" ref="text-left"/>
            <signavio:signavioLabel bold="" fill="#ff0000" fontFamily="" fontSize="" italic="" ref="text-right"/>
         </extensionElements>
         <text>How do they know that the CW Profile has been created?
Is there periodic check?</text>
      </textAnnotation>
      <textAnnotation id="sid-2EADD4F5-6816-447F-BE5C-D1B386022C23" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            <signavio:signavioMetaData metaKey="meta-refnumber" metaValue="[]"/>
         </extensionElements>
         <text>No alert that Shell Profile is created</text>
      </textAnnotation>
   </process>
