    <xs:attribute name="targetInvisibleLeader" type="xs:boolean" use="optional"/>
    <xs:attribute name="labelOffsetX"   type="xs:decimal" use="optional"/>
    <xs:attribute name="labelOffsetY"   type="xs:decimal" use="optional"/>
    <xs:attribute name="labelWidth"     type="xs:decimal" use="optional"/>
    <xs:attribute name="sourceOffsetAlong" type="xs:decimal" use="optional"/>
    <xs:attribute name="targetOffsetAlong" type="xs:decimal" use="optional"/>
    <xs:attribute name="labelAnchor"    type="dgx:LabelAnchorEnum" use="optional"/>
    <xs:attribute name="arrowAtSource"  type="xs:boolean" use="optional"/>
    <!-- schema 1.38 — uml-containment only: move the circle-with-cross marker
         from the target (containing package) end to the source end. -->
    <xs:attribute name="containmentSwapEnd" type="xs:boolean" use="optional"/>
    <xs:attribute name="bottleneck"    type="xs:boolean" use="optional"/>
    <!-- Simulation (v1.24 model / v1.25 export): decision-gateway branch
         routing. An outgoing edge of a decision gateway carries EITHER a
         branchProbability (0..100, BPSim Probability) OR a branchCondition
         (an expression, BPSim Condition); isDefaultFlow marks the else edge. -->
    <xs:attribute name="branchProbability" type="xs:decimal" use="optional"/>
    <xs:attribute name="branchCondition"   type="xs:string"  use="optional"/>
    <xs:attribute name="isDefaultFlow"     type="xs:boolean" use="optional"/>
  </xs:complexType>

  <!-- Waypoints -->
  <xs:complexType name="WaypointListType">
    <xs:sequence>
      <xs:element name="point" type="dgx:PointType" minOccurs="0" maxOccurs="unbounded"/>
    </xs:sequence>
  </xs:complexType>

  <!-- Formal transition labels -->
  <xs:complexType name="TransitionType">
    <xs:attribute name="labelMode" type="dgx:LabelModeEnum" use="optional"/>
    <xs:attribute name="event"     type="xs:string" use="optional"/>
    <xs:attribute name="guard"     type="xs:string" use="optional"/>
    <xs:attribute name="actions"   type="xs:string" use="optional"/>
  </xs:complexType>

  <xs:simpleType name="LabelModeEnum">
    <xs:restriction base="xs:string">
      <xs:enumeration value="informal"/>
      <xs:enumeration value="formal"/>
    </xs:restriction>
  </xs:simpleType>

  <!-- UML association end properties -->
  <xs:complexType name="AssociationEndType">
    <xs:sequence>
      <xs:element name="roleOffset"       type="dgx:PointType" minOccurs="0"/>
      <xs:element name="multOffset"       type="dgx:PointType" minOccurs="0"/>
      <xs:element name="constraintOffset" type="dgx:PointType" minOccurs="0"/>
      <xs:element name="uniqueOffset"     type="dgx:PointType" minOccurs="0"/>
    </xs:sequence>
    <xs:attribute name="role"           type="xs:string"             use="optional"/>
    <xs:attribute name="multiplicity"   type="xs:string"             use="optional"/>
    <xs:attribute name="visibility"     type="dgx:UmlVisibilityEnum" use="optional"/>
    <xs:attribute name="ordered"        type="xs:boolean"            use="optional"/>
    <xs:attribute name="unique"         type="xs:boolean"            use="optional"/>
    <xs:attribute name="qualifier"      type="xs:string"             use="optional"/>
    <xs:attribute name="propertyString" type="xs:string"             use="optional"/>
  </xs:complexType>

  <xs:simpleType name="UmlVisibilityEnum">
    <xs:restriction base="xs:string">
      <xs:enumeration value="+"/>
      <xs:enumeration value="-"/>
      <xs:enumeration value="#"/>
    </xs:restriction>
  </xs:simpleType>

  <!-- UML association name -->
  <xs:complexType name="AssociationNameType">
    <xs:sequence>
      <xs:element name="offset" type="dgx:PointType" minOccurs="0"/>
    </xs:sequence>
    <xs:attribute name="name"             type="xs:string" use="required"/>
    <xs:attribute name="readingDirection" type="dgx:ReadingDirectionEnum" use="optional"/>
  </xs:complexType>

  <xs:simpleType name="ReadingDirectionEnum">
    <xs:restriction base="xs:string">
      <xs:enumeration value="none"/>
      <xs:enumeration value="to-source"/>
      <xs:enumeration value="to-target"/>
    </xs:restriction>
  </xs:simpleType>

  <!-- ============================================================ -->
  <!-- Connector type enum                                           -->
  <!-- ============================================================ -->
  <xs:simpleType name="ConnectorTypeEnum">
    <xs:restriction base="xs:string">
      <xs:enumeration value="sequence"/>
      <xs:enumeration value="message"/>
      <xs:enumeration value="association"/>
      <xs:enumeration value="transition"/>
      <xs:enumeration value="associationBPMN"/>
      <xs:enumeration value="messageBPMN"/>
      <xs:enumeration value="flow"/>
      <xs:enumeration value="uml-association"/>
      <xs:enumeration value="uml-aggregation"/>
      <xs:enumeration value="uml-composition"/>
      <xs:enumeration value="uml-generalisation"/>
      <xs:enumeration value="uml-dependency"/>
      <xs:enumeration value="uml-realisation"/>
      <!-- schema 1.38 — domain-diagram connectors: containment (solid direct
           package-to-package line with a circle-with-cross marker) and note
           anchor (dashed direct line from a Note to any non-note/non-pain-point
           element). -->
      <xs:enumeration value="uml-containment"/>
      <xs:enumeration value="uml-note-anchor"/>
      <!-- schema 1.9 — ArchiMate relationship types. The specific
           relationship sub-flavour is stored in
           connector.properties.relationshipKey and resolved against
           the runtime ArchiMate catalogue. -->
      <!-- Structural -->
      <xs:enumeration value="archi-composition"/>
      <xs:enumeration value="archi-aggregation"/>
      <xs:enumeration value="archi-assignment"/>
      <xs:enumeration value="archi-realisation"/>
      <!-- Dependency -->
      <xs:enumeration value="archi-serving"/>
      <xs:enumeration value="archi-access"/>
      <xs:enumeration value="archi-influence"/>
      <xs:enumeration value="archi-association"/>
      <!-- Dynamic -->
      <xs:enumeration value="archi-triggering"/>
      <xs:enumeration value="archi-flow"/>
      <!-- Other -->
      <xs:enumeration value="archi-specialisation"/>
      <!-- schema 1.15 — pink link from a review-comment note to the
           element it concerns (Phase 3). -->
      <xs:enumeration value="review-comment-link"/>
    </xs:restriction>
  </xs:simpleType>

  <!-- ============================================================ -->
  <!-- Side enum                                                     -->
  <!-- ============================================================ -->
  <xs:simpleType name="SideEnum">
    <xs:restriction base="xs:string">
      <xs:enumeration value="top"/>
      <xs:enumeration value="right"/>
      <xs:enumeration value="bottom"/>
      <xs:enumeration value="left"/>
    </xs:restriction>
  </xs:simpleType>

  <!-- ============================================================ -->
  <!-- Direction type enum                                           -->
  <!-- ============================================================ -->
  <xs:simpleType name="DirectionTypeEnum">
    <xs:restriction base="xs:string">
      <xs:enumeration value="directed"/>
      <xs:enumeration value="non-directed"/>
      <xs:enumeration value="open-directed"/>
      <xs:enumeration value="both"/>
    </xs:restriction>
  </xs:simpleType>

  <!-- ============================================================ -->
  <!-- Routing type enum                                             -->
  <!-- ============================================================ -->
  <xs:simpleType name="RoutingTypeEnum">
    <xs:restriction base="xs:string">
      <xs:enumeration value="direct"/>
      <xs:enumeration value="rectilinear"/>
      <xs:enumeration value="curvilinear"/>
    </xs:restriction>
  </xs:simpleType>

  <!-- ============================================================ -->
  <!-- Label anchor enum                                             -->
  <!-- ============================================================ -->
  <xs:simpleType name="LabelAnchorEnum">
    <xs:restriction base="xs:string">
      <xs:enumeration value="midpoint"/>
      <xs:enumeration value="source"/>
    </xs:restriction>
  </xs:simpleType>

  <!-- ============================================================ -->
  <!-- Folder tree (preserves project organisation)                  -->
  <!-- ============================================================ -->
  <xs:complexType name="FolderTreeType">
    <xs:sequence>
      <xs:element name="folders" type="dgx:FolderListType" minOccurs="0"/>
      <xs:element name="diagramFolderMap" type="dgx:MappingListType" minOccurs="0"/>
      <xs:element name="diagramOrder"     type="dgx:OrderListType"   minOccurs="0"/>
      <xs:element name="folderOrder"      type="dgx:OrderListType"   minOccurs="0"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="FolderListType">
    <xs:sequence>
      <xs:element name="folder" minOccurs="0" maxOccurs="unbounded">
        <xs:complexType>
          <xs:attribute name="id"       type="xs:string"  use="required"/>
          <xs:attribute name="name"     type="xs:string"  use="required"/>
          <xs:attribute name="parentId" type="xs:string"  use="optional"/>
        </xs:complexType>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <!-- Generic key → value mapping (diagramId → folderId) -->
  <xs:complexType name="MappingListType">
    <xs:sequence>
      <xs:element name="entry" minOccurs="0" maxOccurs="unbounded">
        <xs:complexType>
          <xs:attribute name="key"   type="xs:string" use="required"/>
          <xs:attribute name="value" type="xs:string" use="required"/>
        </xs:complexType>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <!-- Generic key → ordered list mapping (folderId → [id1, id2, ...]) -->
  <xs:complexType name="OrderListType">
    <xs:sequence>
      <xs:element name="group" minOccurs="0" maxOccurs="unbounded">
        <xs:complexType>
          <xs:sequence>
            <xs:element name="ref" minOccurs="0" maxOccurs="unbounded">
              <xs:complexType>
                <xs:attribute name="id" type="xs:string" use="required"/>
              </xs:complexType>
            </xs:element>
          </xs:sequence>
          <xs:attribute name="key" type="xs:string" use="required"/>
        </xs:complexType>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

</xs:schema>
